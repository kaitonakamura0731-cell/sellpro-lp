---
// お問い合わせページ — /contact/
// docs.astro と同構成（main.css import・LP共通ヘッダー・フッター）
import BaseLayout from "../layouts/BaseLayout.astro";
import site from "../data/site.json";
import "../styles/main.css";

// お問い合わせ送信先（編集可能 / 管理画面の site.json）:
//   contact.email … 問い合わせの届け先メールアドレス。
//   送信は同一サーバーの /api/contact が受けて SMTP 送信する（server.js）。
//   /api/contact が使えない/未設定の環境では、この宛先への mailto に自動フォールバックする。
const contactEmail = site.contact?.email ?? "geriru0099@gmail.com";

const meta = {
  title: "お問い合わせ | SellPro（セルプロ）- One StepS",
  description:
    "スライド・議事録作成を自動化するAIエージェント「SellPro（セルプロ）」への導入相談・資料請求・デモのご依頼はこちらから。担当者が内容を確認のうえご連絡します。",
};

const ldBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "ホーム",
      item: new URL("/", Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "お問い合わせ",
      item: new URL("/contact/", Astro.site).href,
    },
  ],
};
---

<BaseLayout title={meta.title} description={meta.description} canonical="/contact/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(ldBreadcrumb)} is:inline></script>
  </Fragment>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/" aria-label="SellPro トップへ">
          <img src="../logos/sellpro.svg" alt="SellPro（セルプロ）ロゴ" width="489" height="140" />
        </a>
        <nav class="header-nav" aria-label="ナビゲーション">
          <a href="/">トップ</a>
          <a href="/#features">機能</a>
          <a href="/#reasons">選ばれる理由</a>
          <a href="/docs/">資料</a>
          <a class="btn btn-vivid" href="/contact/">お問い合わせ</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="contact" id="contact" aria-labelledby="contact-h">
        <div class="container contact-grid">
          <div class="contact-copy">
            <h1 id="contact-h">お問い合わせ</h1>
            <p>
              導入のご相談、資料請求、その他のご質問はこちらから。内容を確認のうえ、担当者よりご連絡します。
            </p>
            <p class="contact-hint">
              最短デモ30分／初期費用・最低契約期間の有無もお問い合わせ時にご案内。1分で送信できます。
            </p>
            <p class="mailto-note">
              ※ ご入力内容は担当者宛に送信されます。通常1〜2営業日以内にご返信します。
            </p>
          </div>
          <form class="contact-form" id="contact-form" novalidate data-email={contactEmail}>
            <!-- スパム対策: 人間には見えない。bot が入力すると送信を破棄する -->
            <div class="hp-field" aria-hidden="true">
              <label for="f-website">Webサイト（入力しないでください）</label>
              <input id="f-website" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
            </div>
            <div class="form-row">
              <div class="field">
                <label for="f-name">お名前<span class="req">必須</span></label>
                <input id="f-name" name="name" type="text" autocomplete="name" required />
              </div>
              <div class="field">
                <label for="f-company">会社名<span class="req">必須</span></label>
                <input id="f-company" name="company" type="text" autocomplete="organization" required />
              </div>
            </div>
            <div class="form-row">
              <div class="field">
                <label for="f-email">メールアドレス<span class="req">必須</span></label>
                <input id="f-email" name="email" type="email" autocomplete="email" required />
              </div>
              <div class="field">
                <label for="f-type">お問い合わせ種別</label>
                <select id="f-type" name="type">
                  <option value="導入相談">導入相談</option>
                  <option value="デモ・トライアル相談">デモ・トライアル相談</option>
                  <option value="資料請求">資料請求</option>
                  <option value="その他">その他</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label for="f-body">本文</label>
              <textarea id="f-body" name="body" placeholder="現在の資料作成の体制や、お困りごとをお書きください"></textarea>
            </div>
            <div class="consent-row">
              <label for="f-consent">
                <input id="f-consent" name="consent" type="checkbox" required />
                <span class="consent-text">
                  個人情報の取り扱いに同意する<span class="req">必須</span>
                </span>
              </label>
            </div>
            <button class="btn btn-vivid" id="contact-submit" type="submit">送信する</button>
            <p class="form-status" id="contact-status" role="status" aria-live="polite" hidden></p>
          </form>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="brand" href="/">
              <img src="../logos/sellpro.svg" alt="SellPro（セルプロ）ロゴ" width="489" height="140" />
            </a>
            <p>スライド・議事録作成を自動化するAIエージェント。</p>
          </div>
          <dl class="footer-company">
            <dt>運営会社</dt>
            <dd>株式会社One StepS（ワンステップス）</dd>
            <dd>東京都港区南青山3-8-40 青山センタービル2F-20</dd>
            <dd><a href="https://onesteps.co.jp/" target="_blank" rel="noopener">onesteps.co.jp</a></dd>
            <dd><a href="https://onesteps.co.jp/" target="_blank" rel="noopener">プライバシーポリシー</a></dd>
            <dd><a href="/docs/">資料ダウンロード</a></dd>
          </dl>
        </div>
        <p class="copyright">&copy; 2026 One StepS Inc.</p>
      </div>
    </footer>

    <script is:inline>
      // お問い合わせフォーム（本番）: 同一サーバーの /api/contact へ送信し、サーバーが SMTP でメール送信する。
      // /api/contact が無い静的配信や、SMTP未設定・通信失敗時は mailto フォールバックで送信手段を必ず確保する。
      (function () {
        var form = document.getElementById("contact-form");
        if (!form) return;
        var statusEl = document.getElementById("contact-status");
        var submitBtn = document.getElementById("contact-submit");
        var fallbackEmail = (form.getAttribute("data-email") || "geriru0099@gmail.com").trim();

        function showStatus(msg, kind) {
          if (!statusEl) return;
          statusEl.textContent = msg;
          statusEl.className = "form-status" + (kind ? " is-" + kind : "");
          statusEl.hidden = false;
        }
        function setSending(sending) {
          if (!submitBtn) return;
          submitBtn.disabled = sending;
          submitBtn.textContent = sending ? "送信中…" : "送信する";
        }
        function getVal(id) {
          var el = document.getElementById(id);
          return el ? el.value.trim() : "";
        }
        function buildMailto(data) {
          var lines = [
            "【SellPro お問い合わせ】",
            "お名前: " + data.name,
            "会社名: " + data.company,
            "メールアドレス: " + data.email,
            "種別: " + data.type,
            "",
            "本文:",
            data.body || "（未記入）",
          ];
          var subject = "【SellPro】" + data.type + "（" + data.name + "様）";
          return "mailto:" + fallbackEmail + "?subject=" +
            encodeURIComponent(subject) + "&body=" + encodeURIComponent(lines.join("\n"));
        }

        form.addEventListener("submit", function (e) {
          e.preventDefault();
          var data = {
            name: getVal("f-name"),
            company: getVal("f-company"),
            email: getVal("f-email"),
            type: document.getElementById("f-type").value,
            body: getVal("f-body"),
          };
          var hp = document.getElementById("f-website"); // ハニーポット

          if (!data.name || !data.company || !data.email) {
            showStatus("お名前・会社名・メールアドレスをご入力ください。", "error");
            return;
          }
          // novalidate運用のため、メール形式はJS側で検証する
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
            showStatus("メールアドレスの形式をご確認ください。", "error");
            return;
          }
          var consent = document.getElementById("f-consent");
          if (consent && !consent.checked) {
            showStatus("個人情報の取り扱いへの同意をお願いします。", "error");
            return;
          }
          if (hp && hp.value) {
            // bot とみなし、成功を装って黙って破棄
            showStatus("送信しました。ありがとうございます。", "ok");
            form.reset();
            return;
          }

          // 本番送信: 同一サーバーの /api/contact へ JSON で POST（同一オリジン=CORSなし）。
          setSending(true);
          showStatus("送信しています…", "");

          function fallbackToMailto(msg) {
            setSending(false);
            showStatus(msg, "ok");
            window.location.href = buildMailto(data);
          }

          var payload = {
            name: data.name,
            company: data.company,
            email: data.email,
            type: data.type,
            body: data.body,
            _gotcha: hp ? hp.value : "",
            page: location.href,
          };

          fetch("/api/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          })
            .then(function (res) {
              return res
                .json()
                .catch(function () { return {}; })
                .then(function (json) { return { ok: res.ok, status: res.status, json: json }; });
            })
            .then(function (r) {
              if (r.ok && r.json && r.json.ok) {
                setSending(false);
                form.reset();
                showStatus("送信しました。担当者より通常1〜2営業日以内にご返信します。", "ok");
                return;
              }
              // サーバーは応答したが送信先未設定（SMTP未設定など）→ mailto フォールバック
              if (r.json && r.json.code === "not-configured") {
                fallbackToMailto("メールソフトを起動します。開かない場合は " + fallbackEmail + " 宛にご連絡ください。");
                return;
              }
              // 入力内容のエラー（400）→ その場で表示（フォールバックしない）
              if (r.status === 400 && r.json && r.json.error) {
                setSending(false);
                showStatus(r.json.error, "error");
                return;
              }
              // 404（静的配信）・500 など → mailto フォールバック
              fallbackToMailto("メールソフトでの送信に切り替えます。開かない場合は " + fallbackEmail + " 宛にご連絡ください。");
            })
            .catch(function () {
              fallbackToMailto("通信に失敗したため、メールソフトでの送信に切り替えます。");
            });
        });
      })();

      // クエリパラメータ ?type=xxx でお問い合わせ種別をプリセレクト
      (function () {
        var select = document.getElementById("f-type");
        if (!select) return;
        var params = new URLSearchParams(window.location.search);
        var t = params.get("type");
        if (t) {
          for (var i = 0; i < select.options.length; i++) {
            if (select.options[i].value === t) {
              select.selectedIndex = i;
              break;
            }
          }
        }
      })();
    </script>
</BaseLayout>
