---
// 資料一覧ページ — コンテンツファイル方式（CMS）。
// 掲載資料は src/data/docs.json で管理する。
// 実ファイルは public/docs/ に置き、JSON の file はそのパス（例: "docs/foo.pdf"）を指定する。
// available:false は「準備中」のグレーカードとして表示する。
import "../styles/exa.css";
import docs from "../data/docs.json";

const meta = {
  title: "資料ダウンロード | SellPro（セルプロ）- One StepS",
  description:
    "SellPro（セルプロ）の説明資料・導入事例集などをダウンロードいただけます。サービス概要・機能・活用事例をまとめた資料をご用意しています。",
};

// public 配下の実ファイルサイズ（available:true のもの）を読み取り、KB/MB 表記にする。
import fs from "node:fs";
import path from "node:path";

function humanSize(bytes) {
  if (!bytes || bytes <= 0) return "";
  if (bytes < 1024 * 1024) return Math.round(bytes / 1024) + " KB";
  return (bytes / (1024 * 1024)).toFixed(1) + " MB";
}

const items = docs.map((d) => {
  let size = "";
  if (d.available && d.file) {
    try {
      const stat = fs.statSync(path.join(process.cwd(), "public", d.file));
      size = humanSize(stat.size);
    } catch (e) {
      size = "";
    }
  }
  const ext = d.file ? d.file.split(".").pop().toUpperCase() : "";
  return { ...d, size, ext };
});
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:image" content="product/og.png" />
    <meta property="og:site_name" content="SellPro（セルプロ）" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="../logos/sellpro.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/" aria-label="SellPro トップへ">
          <img src="../logos/sellpro.svg" alt="SellPro（セルプロ）ロゴ" width="489" height="140" />
        </a>
        <nav class="header-nav" aria-label="ナビゲーション">
          <a href="/">トップ</a>
          <a href="/#features">機能</a>
          <a href="/#reasons">選ばれる理由</a>
          <a class="btn btn-vivid" href="/contact/">お問い合わせ</a>
        </nav>
      </div>
    </header>

    <main class="docs-page">
      <section class="docs-hero">
        <div class="container">
          <p class="docs-eyebrow">DOWNLOAD</p>
          <h1>資料ダウンロード</h1>
          <p class="docs-lead">
            SellProの説明資料や導入事例集をご用意しています。ご検討にあわせてご活用ください。
          </p>
        </div>
      </section>

      <section class="docs-list">
        <div class="container">
          <div class="docs-grid">
            {
              items.map((d) => (
                <article class={d.available ? "doc-card" : "doc-card is-pending"}>
                  <div class="doc-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="26" height="26">
                      <path
                        d="M6 2.5h7.5L19 8v13.5H6z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M13.5 2.5V8H19"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                  <div class="doc-body">
                    <h2 class="doc-title">{d.title}</h2>
                    <p class="doc-desc">{d.description}</p>
                    <p class="doc-file-meta">
                      {d.available ? (
                        <>
                          {d.ext && <span class="doc-tag">{d.ext}</span>}
                          {d.size && <span class="doc-size">{d.size}</span>}
                          {d.date && <span class="doc-date">{d.date}</span>}
                        </>
                      ) : (
                        <span class="doc-pending-label">準備中</span>
                      )}
                    </p>
                  </div>
                  <div class="doc-action">
                    {d.available ? (
                      <a class="btn btn-vivid doc-dl" href={d.file} download>
                        ダウンロード
                      </a>
                    ) : (
                      <span class="btn doc-dl-disabled" aria-disabled="true">
                        準備中
                      </span>
                    )}
                  </div>
                </article>
              ))
            }
          </div>
          <aside class="docs-trial">
            <h2>無料トライアル申し込み</h2>
            <p>実際の業務資料でSellProをお試しいただけます。デモのご案内も可能です。</p>
            <a class="btn btn-vivid" href="/contact/?type=%E3%83%87%E3%83%A2%E3%83%BB%E3%83%88%E3%83%A9%E3%82%A4%E3%82%A2%E3%83%AB%E7%9B%B8%E8%AB%87">無料トライアルを申し込む</a>
          </aside>
          <p class="docs-back">
            <a href="/">&larr; トップページへ戻る</a>
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a class="brand" href="/">
              <img src="../logos/sellpro.svg" alt="SellPro（セルプロ）ロゴ" width="489" height="140" />
            </a>
            <p>スライド・議事録作成を自動化するAIエージェント。</p>
          </div>
          <dl class="footer-company">
            <dt>運営会社</dt>
            <dd>株式会社One StepS（ワンステップス）</dd>
            <dd>東京都港区南青山3-8-40 青山センタービル2F-20</dd>
            <dd><a href="https://onesteps.co.jp/" target="_blank" rel="noopener">onesteps.co.jp</a></dd>
            <dd><a href="/docs/">資料ダウンロード</a></dd>
          </dl>
        </div>
        <p class="copyright">&copy; 2026 One StepS Inc.</p>
      </div>
    </footer>

    <style>
      .docs-page {
        background: var(--bg-soft);
        min-height: 60vh;
      }

      .docs-hero {
        padding: 64px 0 28px;
        background: linear-gradient(180deg, #fff 0%, var(--bg-soft) 100%);
      }

      .docs-eyebrow {
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.12em;
        color: var(--blue);
        margin-bottom: 10px;
      }

      .docs-hero h1 {
        font-size: 34px;
        font-weight: 800;
        color: var(--navy);
        line-height: 1.3;
      }

      .docs-lead {
        margin-top: 14px;
        max-width: 640px;
        color: var(--muted);
      }

      .docs-list {
        padding: 8px 0 88px;
      }

      .docs-grid {
        display: grid;
        gap: 18px;
        grid-template-columns: 1fr;
      }

      .doc-card {
        display: flex;
        align-items: center;
        gap: 20px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 22px 24px;
        box-shadow: 0 6px 20px rgba(8, 32, 74, 0.06);
      }

      .doc-card.is-pending {
        background: #f5f7fa;
        border-color: #e4e9f0;
        box-shadow: none;
      }

      .doc-icon {
        flex: 0 0 auto;
        width: 52px;
        height: 52px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: var(--bg-tint);
        color: var(--blue);
      }

      .doc-card.is-pending .doc-icon {
        background: #eceff3;
        color: #9aa6b4;
      }

      .doc-body {
        flex: 1 1 auto;
        min-width: 0;
      }

      .doc-title {
        font-size: 19px;
        font-weight: 800;
        color: var(--navy);
        line-height: 1.4;
      }

      .doc-card.is-pending .doc-title {
        color: #7a8594;
      }

      .doc-desc {
        margin-top: 6px;
        font-size: 15px;
        color: var(--muted);
        line-height: 1.7;
      }

      .doc-file-meta {
        margin-top: 12px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        font-size: 13px;
      }

      .doc-tag {
        font-weight: 800;
        color: var(--blue);
        background: var(--bg-tint);
        padding: 2px 9px;
        border-radius: 6px;
        letter-spacing: 0.04em;
      }

      .doc-size,
      .doc-date {
        color: var(--muted);
      }

      .doc-pending-label {
        font-weight: 700;
        color: #9aa6b4;
        background: #eceff3;
        padding: 2px 12px;
        border-radius: 999px;
      }

      .doc-action {
        flex: 0 0 auto;
      }

      .doc-dl {
        font-size: 15px;
        padding: 12px 26px;
      }

      .doc-dl-disabled {
        font-size: 15px;
        padding: 12px 26px;
        background: #e4e9f0;
        color: #9aa6b4;
        cursor: not-allowed;
        box-shadow: none;
      }

      .docs-trial {
        margin-top: 28px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 28px 26px;
        text-align: center;
        box-shadow: 0 6px 20px rgba(8, 32, 74, 0.06);
      }

      .docs-trial h2 {
        font-size: 21px;
        font-weight: 800;
        color: var(--navy);
        line-height: 1.4;
      }

      .docs-trial p {
        margin-top: 10px;
        font-size: 15px;
        color: var(--muted);
        line-height: 1.7;
      }

      .docs-trial .btn {
        margin-top: 18px;
        font-size: 15px;
        padding: 12px 28px;
      }

      .docs-back {
        margin-top: 40px;
        font-size: 15px;
      }

      .docs-back a {
        color: var(--blue);
        font-weight: 600;
      }

      .docs-back a:hover {
        color: var(--blue-deep);
      }

      @media (max-width: 560px) {
        .docs-hero h1 {
          font-size: 27px;
        }

        .doc-card {
          flex-wrap: wrap;
          gap: 14px;
          padding: 20px;
        }

        .doc-body {
          flex: 1 1 100%;
          order: 2;
          min-width: 100%;
        }

        .doc-icon {
          order: 1;
        }

        .doc-action {
          order: 3;
          flex: 1 1 100%;
        }

        .doc-dl,
        .doc-dl-disabled {
          width: 100%;
        }
      }
    </style>
  </body>
</html>
