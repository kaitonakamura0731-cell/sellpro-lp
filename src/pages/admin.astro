---
// =============================================================================
// SellPro コンテンツ管理（CMS） — Studio 風・モバイルファースト
//
// 体験設計: ホーム(コンテンツ一覧) → 種別をタップ → アイテム一覧 → 編集
//   配列型(資料/インタビュー/ロゴ/FAQ): 一覧で 追加 / 編集 / 削除 / 並び替え
//   単体型(バナー): タップで直接編集
//   プレビュー: 編集画面から全画面オーバーレイで実ページ忠実表示
//
// 認証: パスワードのみ。X-Admin-Password ヘッダ + sessionStorage 保持。
// データ: GET/POST /api/admin-content?key=...  （既存API・変更不可）
// 画像: POST /api/admin-upload?folder=...      （アップロードAPI）
//
// このファイルは1ファイル自己完結。JS は論理セクションで分割:
//   CONST / STATE / UTIL / API / UPLOAD / VIEWS / FORMS / PREVIEW / EVENTS
// =============================================================================
const PAGE_TITLE = "SellPro コンテンツ管理";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="format-detection" content="telephone=no" />
    <title>{PAGE_TITLE}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      /* ===================================================================
         DESIGN TOKENS
         =================================================================== */
      :root {
        --blue: #1463ff;
        --blue-dark: #0c4ad0;
        --blue-soft: #eef3ff;
        --blue-ring: rgba(20, 99, 255, 0.18);

        --ink: #0e1726;
        --ink-2: #44506a;
        --ink-3: #6b748a;

        --bg: #f4f6fb;
        --card: #ffffff;
        --line: #e6e9f2;
        --line-2: #eef0f6;

        --danger: #d6294a;
        --danger-soft: #fdeef1;
        --ok: #138a5a;

        --r-lg: 22px;
        --r-md: 16px;
        --r-sm: 11px;

        --shadow-card: 0 1px 2px rgba(16, 23, 38, 0.04), 0 8px 24px rgba(16, 23, 38, 0.06);
        --shadow-pop: 0 12px 40px rgba(16, 23, 38, 0.16);
        --shadow-bar: 0 1px 0 var(--line);

        --maxw: 760px;
        --bar-h: 60px;
        --ease: cubic-bezier(0.22, 0.61, 0.36, 1);

        --safe-t: env(safe-area-inset-top, 0px);
        --safe-b: env(safe-area-inset-bottom, 0px);
      }

      /* ===================================================================
         RESET — モバイル横はみ出しを構造的に封じる
         =================================================================== */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        max-width: 100%;
        overflow-x: hidden; /* 横スクロール根絶 */
      }
      html {
        -webkit-text-size-adjust: 100%;
        text-size-adjust: 100%;
      }
      body {
        font-family: "Zen Kaku Gothic New", system-ui, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        word-break: break-word;
        overflow-wrap: anywhere; /* 長いURL/文字列でも溢れさせない */
      }
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
      button {
        font-family: inherit;
        cursor: pointer;
        border: none;
        background: none;
        color: inherit;
      }
      input,
      textarea,
      select {
        font-family: inherit;
        font-size: 16px; /* iOS のフォーカス時ズーム防止 */
        color: inherit;
        max-width: 100%;
      }
      a {
        color: var(--blue);
        text-decoration: none;
      }
      :focus-visible {
        outline: 3px solid var(--blue);
        outline-offset: 2px;
      }

      /* ===================================================================
         APP SHELL
         =================================================================== */
      .app {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
      }
      .wrap {
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: clamp(14px, 4vw, 28px);
      }

      /* --- Top bar -------------------------------------------------------- */
      .bar {
        position: sticky;
        top: 0;
        z-index: 40;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: saturate(1.4) blur(8px);
        -webkit-backdrop-filter: saturate(1.4) blur(8px);
        box-shadow: var(--shadow-bar);
        padding-top: var(--safe-t);
      }
      .bar-inner {
        height: var(--bar-h);
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: clamp(10px, 3.5vw, 20px);
      }
      .bar-title {
        flex: 1 1 auto;
        min-width: 0; /* flex 子の溢れ防止 */
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 0.01em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        text-align: center;
      }
      .bar-back {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        height: 38px;
        padding: 0 12px 0 8px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        color: var(--blue);
        background: var(--blue-soft);
        transition: background 0.15s var(--ease), transform 0.1s var(--ease);
      }
      .bar-back:active {
        transform: scale(0.96);
      }
      .bar-back svg {
        width: 16px;
        height: 16px;
      }
      .bar-save {
        flex: 0 0 auto;
        height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        background: var(--blue);
        box-shadow: 0 4px 14px var(--blue-ring);
        transition: background 0.15s var(--ease), transform 0.1s var(--ease), opacity 0.15s;
      }
      .bar-save:active {
        transform: scale(0.96);
      }
      .bar-save[disabled] {
        opacity: 0.5;
        pointer-events: none;
        box-shadow: none;
      }
      .bar-slot {
        flex: 0 0 auto;
        min-width: 44px;
        display: flex;
        justify-content: flex-end;
        gap: 2px;
        align-items: center;
      }
      .bar-ghost {
        font-size: 13px;
        font-weight: 700;
        color: var(--ink-3);
        padding: 8px 10px;
        border-radius: 999px;
      }

      /* --- Hamburger button (mobile only) ---------------------------------- */
      .ham-btn {
        flex: 0 0 auto;
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        border-radius: 12px;
        color: var(--ink);
        background: none;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
      }
      .ham-btn:active { background: var(--blue-soft); }
      .ham-btn svg { width: 22px; height: 22px; display: block; }
      @media (min-width: 1024px) { .ham-btn { display: none !important; } }

      /* --- Drawer scrim (mobile only) -------------------------------------- */
      .ham-scrim {
        position: fixed;
        inset: 0;
        z-index: 49;
        background: rgba(14, 23, 38, 0.46);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s var(--ease);
      }
      .ham-scrim.is-open { opacity: 1; pointer-events: auto; }
      @media (min-width: 1024px) { .ham-scrim { display: none !important; } }

      /* --- Drawer panel (mobile only) -------------------------------------- */
      .ham-drawer {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 50;
        width: 272px;
        max-width: calc(100vw - 56px);
        background: var(--nav-bg, #1e2330);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform: translateX(-100%);
        transition: transform 0.28s var(--ease);
        box-shadow: 4px 0 32px rgba(14, 23, 38, 0.28);
      }
      .ham-drawer.is-open { transform: translateX(0); }
      @media (min-width: 1024px) { .ham-drawer { display: none !important; } }

      /* drawer header */
      .ham-drawer-head {
        flex: 0 0 auto;
        height: 56px;
        padding-top: var(--safe-t);
        box-sizing: content-box;
        display: flex;
        align-items: center;
        gap: 10px;
        padding-inline: 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }
      .ham-drawer-brand-ico {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        background: #1463ff;
        color: #fff;
        font-size: 13px;
        font-weight: 900;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
      }
      .ham-drawer-brand-name {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.88);
        flex: 1 1 auto;
      }
      .ham-drawer-close {
        flex: 0 0 auto;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: grid;
        place-items: center;
        color: rgba(255, 255, 255, 0.5);
        background: none;
        border: none;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
      }
      .ham-drawer-close:hover { background: rgba(255,255,255,0.08); color: #fff; }
      .ham-drawer-close svg { width: 18px; height: 18px; }

      /* drawer nav */
      .ham-drawer-nav {
        flex: 1 1 auto;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 8px 0 24px;
        display: flex;
        flex-direction: column;
        gap: 1px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.1) transparent;
      }
      .ham-drawer-nav::-webkit-scrollbar { width: 4px; }
      .ham-drawer-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

      /* drawer tabs (reuse desktop side-tab visual) */
      .ham-tab {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 0;
        border: none;
        background: none;
        cursor: pointer;
        text-align: left;
        color: rgba(255, 255, 255, 0.65);
        font-family: inherit;
        transition: color 0.13s;
      }
      .ham-tab-inner {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 10px 16px 10px 14px;
        border-left: 3px solid transparent;
        transition: background 0.13s, border-color 0.13s;
      }
      .ham-tab:hover .ham-tab-inner { background: rgba(255,255,255,0.06); }
      .ham-tab:hover { color: rgba(255,255,255,0.9); }
      .ham-tab.is-active { color: #fff; }
      .ham-tab.is-active .ham-tab-inner {
        background: rgba(20,99,255,0.22);
        border-left-color: #1463ff;
      }
      .ham-tab-ico {
        flex: 0 0 auto;
        width: 28px;
        height: 28px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: transparent;
        overflow: visible;
      }
      .ham-tab-ico img { filter: drop-shadow(0 2px 4px rgba(0,0,0,0.35)); }
      .ham-tab-tx { flex: 1 1 auto; min-width: 0; }
      .ham-tab-name {
        font-size: 13px;
        font-weight: 600;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
      }
      .ham-tab-meta {
        font-size: 11px;
        display: block;
        margin-top: 1px;
        color: rgba(255,255,255,0.42);
        font-weight: 500;
      }
      .ham-tab.is-active .ham-tab-meta { color: rgba(255,255,255,0.55); }
      .ham-section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.38);
        padding: 12px 18px 4px;
        text-transform: uppercase;
      }

      /* --- Main scroll area ---------------------------------------------- */
      .main {
        flex: 1 1 auto;
        padding-top: 18px;
        padding-bottom: calc(48px + var(--safe-b));
      }
      .view {
        animation: viewin 0.32s var(--ease) both;
      }
      @keyframes viewin {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .view {
          animation: none;
        }
      }

      .page-head {
        margin: 4px 0 18px;
      }
      .page-eyebrow {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: var(--blue);
        margin: 0 0 4px;
      }
      .page-title {
        font-size: clamp(22px, 6vw, 28px);
        font-weight: 900;
        letter-spacing: -0.01em;
        margin: 0;
        line-height: 1.3;
      }
      .page-sub {
        margin: 6px 0 0;
        font-size: 14px;
        color: var(--ink-2);
      }

      /* ===================================================================
         HOME — コンテンツ種別カード
         =================================================================== */
      .home-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .home-card {
        display: flex;
        align-items: center;
        gap: 14px;
        width: 100%;
        text-align: left;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 14px 16px;
        box-shadow: 0 1px 2px rgba(16,23,38,0.03), 0 6px 20px rgba(16,23,38,0.05);
        transition: transform 0.15s var(--ease), box-shadow 0.2s var(--ease), border-color 0.2s;
      }
      .home-card:hover {
        border-color: #cdd6f0;
        box-shadow: 0 2px 4px rgba(16,23,38,0.04), 0 14px 32px rgba(16,23,38,0.09);
        transform: translateY(-1px);
      }
      .home-card:active {
        transform: scale(0.985) translateY(0);
      }
      .home-ico {
        flex: 0 0 auto;
        width: 56px;
        height: 56px;
        display: grid;
        place-items: center;
        border-radius: 16px;
        background: linear-gradient(160deg, #f3f7ff, #e6eeff);
        box-shadow: inset 0 0 0 1px rgba(20, 99, 255, 0.06);
      }
      .home-ico img { filter: drop-shadow(0 2px 4px rgba(20, 99, 255, 0.12)); }
      .home-tx {
        flex: 1 1 auto;
        min-width: 0;
      }
      .home-name {
        font-size: 16px;
        font-weight: 700;
        margin: 0;
        line-height: 1.4;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .home-desc {
        font-size: 12.5px;
        color: var(--ink-3);
        margin: 2px 0 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .home-meta {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--ink-3);
      }
      .home-count {
        font-size: 13px;
        font-weight: 700;
        color: var(--ink-2);
        white-space: nowrap;
      }
      .home-chev {
        width: 18px;
        height: 18px;
        flex: 0 0 auto;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11.5px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 999px;
        white-space: nowrap;
      }
      .pill-on {
        color: var(--ok);
        background: #e7f6ef;
      }
      .pill-off {
        color: var(--ink-3);
        background: #eef0f6;
      }
      .pill-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
      }

      /* ===================================================================
         LIST — 配列型アイテム一覧
         =================================================================== */
      .list-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 14px;
      }
      .list-count {
        font-size: 13px;
        font-weight: 700;
        color: var(--ink-3);
      }
      .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        height: 42px;
        padding: 0 18px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        background: var(--blue);
        box-shadow: 0 4px 14px var(--blue-ring);
        transition: transform 0.1s var(--ease), background 0.15s;
      }
      .btn-add:active {
        transform: scale(0.96);
      }
      .btn-add svg {
        width: 17px;
        height: 17px;
      }

      .item-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .item-card {
        display: flex;
        align-items: center;
        gap: 13px;
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--r-md);
        padding: 12px;
        box-shadow: var(--shadow-card);
      }
      .item-thumb {
        flex: 0 0 auto;
        width: 54px;
        height: 54px;
        border-radius: 12px;
        background: var(--blue-soft);
        display: grid;
        place-items: center;
        overflow: hidden;
        color: var(--ink-3);
        font-size: 20px;
      }
      .item-thumb img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 4px;
      }
      .item-thumb.is-logo {
        background: #fff;
        border: 1px solid var(--line-2);
      }
      .item-main {
        flex: 1 1 auto;
        min-width: 0;
      }
      .item-tap {
        display: block;
        text-align: left;
        width: 100%;
        min-width: 0;
      }
      .item-title {
        font-size: 15px;
        font-weight: 700;
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .item-sub {
        font-size: 12.5px;
        color: var(--ink-3);
        margin: 3px 0 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .item-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-top: 6px;
      }
      .tag {
        font-size: 11px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 999px;
        background: #eef0f6;
        color: var(--ink-2);
      }
      .tag-sample {
        background: #fff4e5;
        color: #b06d00;
      }
      .tag-off {
        background: #eef0f6;
        color: #6b748a;
      }
      .item-actions {
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .ic-btn {
        width: 36px;
        height: 36px;
        display: grid;
        place-items: center;
        border-radius: 9px;
        color: var(--ink-2);
        background: #f2f4fa;
        transition: background 0.15s, color 0.15s, transform 0.1s;
      }
      .ic-btn svg {
        width: 16px;
        height: 16px;
      }
      .ic-btn:active {
        transform: scale(0.9);
      }
      .ic-btn:disabled {
        opacity: 0.35;
        pointer-events: none;
      }
      .ic-btn.is-danger {
        color: var(--danger);
        background: var(--danger-soft);
      }
      .item-arrows {
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      /* ===================================================================
         FORM — 編集画面
         =================================================================== */
      .form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .field {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--r-md);
        padding: 15px 15px 16px;
        box-shadow: var(--shadow-card);
      }
      .field-label {
        display: block;
        font-size: 14px;
        font-weight: 700;
        margin: 0 0 3px;
      }
      .field-help {
        font-size: 12px;
        color: var(--ink-3);
        margin: 0 0 10px;
        line-height: 1.6;
      }
      .field-help:last-child {
        margin-bottom: 0;
      }
      .input,
      .textarea {
        width: 100%;
        display: block;
        background: #fbfcfe;
        border: 1.5px solid var(--line);
        border-radius: var(--r-sm);
        padding: 12px 13px;
        line-height: 1.6;
        transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
      }
      .input:focus,
      .textarea:focus {
        outline: none;
        border-color: var(--blue);
        background: #fff;
        box-shadow: 0 0 0 4px var(--blue-ring);
      }
      .textarea {
        resize: vertical;
        min-height: 96px;
      }

      /* toggle */
      .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .toggle-tx {
        min-width: 0;
      }
      .switch {
        flex: 0 0 auto;
        position: relative;
        width: 52px;
        height: 31px;
        border-radius: 999px;
        background: #d5dae6;
        transition: background 0.2s var(--ease);
      }
      .switch[aria-checked="true"] {
        background: var(--blue);
      }
      .switch::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 25px;
        height: 25px;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        transition: transform 0.2s var(--ease);
      }
      .switch[aria-checked="true"]::after {
        transform: translateX(21px);
      }

      /* uploader */
      .uploader {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .up-preview {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: var(--r-sm);
        background: #f6f8fc repeating-linear-gradient(
            45deg,
            transparent,
            transparent 10px,
            rgba(0, 0, 0, 0.012) 10px,
            rgba(0, 0, 0, 0.012) 20px
          );
        border: 1.5px dashed var(--line);
        display: grid;
        place-items: center;
        overflow: hidden;
        color: var(--ink-3);
        font-size: 13px;
        text-align: center;
        padding: 14px;
        max-width: 520px;
        max-height: 360px;
      }
      .up-preview.is-logo {
        aspect-ratio: 1 / 1;
        max-width: 160px;
      }
      .up-preview.is-avatar {
        aspect-ratio: 1 / 1;
        max-width: 150px;
        border-radius: 50%;
      }
      .up-preview.is-pdf {
        aspect-ratio: auto;
        min-height: 110px;
        flex-direction: column;
        gap: 8px;
      }
      .up-preview img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
      .up-preview .up-ph-ico {
        font-size: 30px;
      }
      .up-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .btn-up {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        height: 44px;
        padding: 0 18px;
        border-radius: var(--r-sm);
        font-size: 14px;
        font-weight: 700;
        color: var(--blue);
        background: var(--blue-soft);
        border: 1.5px solid transparent;
        transition: background 0.15s, transform 0.1s;
      }
      .btn-up:active {
        transform: scale(0.97);
      }
      .btn-up svg {
        width: 17px;
        height: 17px;
      }
      .btn-up[disabled] {
        opacity: 0.6;
        pointer-events: none;
      }
      .up-status {
        font-size: 12.5px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 7px;
      }
      .up-status.is-busy {
        color: var(--blue);
      }
      .up-status.is-ok {
        color: var(--ok);
      }
      .up-status.is-err {
        color: var(--danger);
      }
      .spin {
        width: 14px;
        height: 14px;
        border: 2px solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .adv {
        margin-top: 2px;
        border-top: 1px solid var(--line-2);
        padding-top: 10px;
      }
      .adv summary {
        font-size: 13px;
        font-weight: 700;
        color: var(--ink-3);
        cursor: pointer;
        list-style: none;
        user-select: none;
        padding: 6px 0;
      }
      .adv summary::-webkit-details-marker {
        display: none;
      }
      .adv summary::before {
        content: "▸ ";
      }
      .adv[open] summary::before {
        content: "▾ ";
      }
      .adv .input {
        margin-top: 9px;
      }

      /* Q&A repeater (interview) */
      .qa-block {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .qa-item {
        border: 1px solid var(--line-2);
        border-radius: var(--r-sm);
        padding: 12px;
        background: #fbfcfe;
        position: relative;
      }
      .qa-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
      }
      .qa-no {
        font-size: 12px;
        font-weight: 700;
        color: var(--blue);
      }
      .qa-item .input,
      .qa-item .textarea {
        background: #fff;
      }
      .qa-item .input + .textarea {
        margin-top: 8px;
      }
      .btn-line {
        width: 100%;
        height: 44px;
        border-radius: var(--r-sm);
        font-size: 14px;
        font-weight: 700;
        color: var(--blue);
        background: var(--blue-soft);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: background 0.15s, transform 0.1s;
      }
      .btn-line:active {
        transform: scale(0.98);
      }
      .btn-line.is-danger {
        color: var(--danger);
        background: var(--danger-soft);
      }
      .btn-line svg {
        width: 16px;
        height: 16px;
      }

      .form-foot {
        margin-top: 6px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .btn-primary-full {
        width: 100%;
        height: 54px;
        border-radius: var(--r-md);
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        background: var(--blue);
        box-shadow: 0 4px 16px var(--blue-ring);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.1s var(--ease), opacity 0.15s;
      }
      .btn-primary-full:active {
        transform: scale(0.985);
      }
      .btn-primary-full[disabled] {
        opacity: 0.55;
        pointer-events: none;
        box-shadow: none;
      }
      .btn-preview {
        width: 100%;
        height: 50px;
        border-radius: var(--r-md);
        font-size: 15px;
        font-weight: 700;
        color: var(--ink);
        background: #fff;
        border: 1.5px solid var(--line);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: var(--shadow-card);
        transition: transform 0.1s, border-color 0.15s;
      }
      .btn-preview:active {
        transform: scale(0.985);
      }
      .btn-preview svg {
        width: 18px;
        height: 18px;
        color: var(--blue);
      }

      /* ===================================================================
         PREVIEW OVERLAY
         =================================================================== */
      .ov {
        position: fixed;
        inset: 0;
        z-index: 60;
        display: flex;
        flex-direction: column;
        background: var(--bg);
        animation: ovin 0.3s var(--ease) both;
      }
      @keyframes ovin {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .ov-bar {
        flex: 0 0 auto;
        height: var(--bar-h);
        padding-top: var(--safe-t);
        box-sizing: content-box;
        display: flex;
        align-items: center;
        gap: 10px;
        padding-inline: clamp(12px, 4vw, 20px);
        background: #fff;
        box-shadow: var(--shadow-bar);
      }
      .ov-title {
        flex: 1 1 auto;
        min-width: 0;
        font-size: 15px;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .ov-badge {
        flex: 0 0 auto;
        font-size: 11px;
        font-weight: 700;
        color: var(--blue);
        background: var(--blue-soft);
        padding: 4px 10px;
        border-radius: 999px;
      }
      .ov-close {
        flex: 0 0 auto;
        width: 38px;
        height: 38px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        background: #f2f4fa;
        color: var(--ink-2);
      }
      .ov-close svg {
        width: 18px;
        height: 18px;
      }
      .ov-body {
        flex: 1 1 auto;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        padding: 16px clamp(12px, 4vw, 20px) calc(40px + var(--safe-b));
      }
      .ov-note {
        max-width: var(--maxw);
        margin: 0 auto 14px;
        font-size: 12.5px;
        color: var(--ink-2);
        background: var(--blue-soft);
        border-radius: var(--r-sm);
        padding: 10px 13px;
        line-height: 1.6;
      }
      .pv-frame {
        max-width: var(--maxw);
        margin-inline: auto;
      }

      /* ---- preview faithful styles (LP の実セクション再現) ---- */
      .pv-banner {
        position: relative;
        border-radius: var(--r-md);
        overflow: hidden;
        box-shadow: var(--shadow-card);
        border: 1px solid var(--line);
        background: #fff;
      }
      .pv-banner img {
        width: 100%;
        display: block;
      }
      .pv-banner.is-off {
        opacity: 0.45;
        filter: grayscale(0.4);
      }
      .pv-off-tag {
        position: absolute;
        top: 10px;
        left: 10px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        background: rgba(14, 23, 38, 0.7);
        padding: 4px 10px;
        border-radius: 999px;
      }

      .pv-iv {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 20px;
        box-shadow: var(--shadow-card);
        position: relative;
      }
      .pv-iv-chip {
        position: absolute;
        top: 14px;
        right: 14px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #b06d00;
        background: #fff4e5;
        padding: 3px 9px;
        border-radius: 999px;
      }
      .pv-iv-head {
        display: flex;
        align-items: center;
        gap: 13px;
        padding-right: 70px;
        margin-bottom: 14px;
      }
      .pv-iv-av {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        overflow: hidden;
        flex: 0 0 auto;
        background: var(--blue-soft);
      }
      .pv-iv-av img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .pv-iv-org {
        font-weight: 700;
        margin: 0;
        font-size: 15px;
      }
      .pv-iv-scale {
        margin: 2px 0 0;
        font-size: 12.5px;
        color: var(--ink-3);
      }
      .pv-iv-qa {
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .pv-iv-qa dt {
        font-weight: 700;
        font-size: 14px;
        display: flex;
        gap: 8px;
        margin-bottom: 4px;
      }
      .pv-iv-qa .qmark {
        flex: 0 0 auto;
        width: 22px;
        height: 22px;
        border-radius: 6px;
        background: var(--blue);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        display: grid;
        place-items: center;
      }
      .pv-iv-qa dd {
        margin: 0 0 0 30px;
        font-size: 14px;
        color: var(--ink-2);
      }

      .pv-faq {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--r-md);
        padding: 18px 18px;
        box-shadow: var(--shadow-card);
      }
      .pv-faq-q {
        font-weight: 700;
        font-size: 15px;
        display: flex;
        gap: 9px;
        line-height: 1.5;
      }
      .pv-faq-q .qn {
        flex: 0 0 auto;
        color: var(--blue);
        font-weight: 900;
      }
      .pv-faq-a {
        margin: 10px 0 0 27px;
        font-size: 14px;
        color: var(--ink-2);
      }

      .pv-doc {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--r-md);
        padding: 18px;
        box-shadow: var(--shadow-card);
        display: flex;
        gap: 14px;
        align-items: flex-start;
      }
      .pv-doc-ico {
        flex: 0 0 auto;
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--blue-soft);
        color: var(--blue);
        display: grid;
        place-items: center;
        font-size: 22px;
      }
      .pv-doc-t {
        font-weight: 700;
        margin: 0;
        font-size: 16px;
      }
      .pv-doc-d {
        margin: 4px 0 0;
        font-size: 13.5px;
        color: var(--ink-2);
      }
      .pv-doc-meta {
        margin: 8px 0 0;
        font-size: 12px;
        color: var(--ink-3);
      }

      .pv-logos {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--r-md);
        padding: 18px;
        box-shadow: var(--shadow-card);
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      .pv-logo {
        aspect-ratio: 16 / 9;
        border: 1px solid var(--line-2);
        border-radius: 10px;
        display: grid;
        place-items: center;
        padding: 10px;
        background: #fff;
      }
      .pv-logo img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
      }

      /* ===================================================================
         EMPTY / SKELETON / TOAST / DIALOG
         =================================================================== */
      .empty {
        text-align: center;
        padding: 44px 20px;
        color: var(--ink-3);
      }
      .empty-ico {
        font-size: 38px;
        margin-bottom: 8px;
      }
      .skel {
        background: linear-gradient(100deg, #eef1f7 30%, #f7f9fc 50%, #eef1f7 70%);
        background-size: 200% 100%;
        animation: shimmer 1.3s linear infinite;
        border-radius: var(--r-md);
      }
      @keyframes shimmer {
        to {
          background-position: -200% 0;
        }
      }
      .skel-card {
        height: 84px;
        margin-bottom: 12px;
      }

      .toast {
        position: fixed;
        left: 50%;
        bottom: calc(20px + var(--safe-b));
        transform: translateX(-50%) translateY(20px);
        z-index: 80;
        max-width: calc(100vw - 28px);
        background: var(--ink);
        color: #fff;
        font-size: 13.5px;
        font-weight: 600;
        padding: 12px 16px;
        border-radius: 13px;
        box-shadow: var(--shadow-pop);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s var(--ease), transform 0.25s var(--ease);
        display: flex;
        align-items: center;
        gap: 9px;
        line-height: 1.5;
      }
      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }
      .toast a {
        color: #9ec2ff;
        font-weight: 700;
        white-space: nowrap;
      }
      .toast.is-err {
        background: var(--danger);
      }

      .dlg-back {
        position: fixed;
        inset: 0;
        z-index: 90;
        background: rgba(14, 23, 38, 0.4);
        display: grid;
        place-items: center;
        padding: 22px;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s var(--ease);
      }
      .dlg-back.show {
        opacity: 1;
        pointer-events: auto;
      }
      .dlg {
        width: 100%;
        max-width: 340px;
        background: #fff;
        border-radius: 20px;
        padding: 22px;
        box-shadow: var(--shadow-pop);
        transform: scale(0.94);
        transition: transform 0.2s var(--ease);
      }
      .dlg-back.show .dlg {
        transform: scale(1);
      }
      .dlg-t {
        font-size: 17px;
        font-weight: 700;
        margin: 0 0 6px;
      }
      .dlg-m {
        font-size: 13.5px;
        color: var(--ink-2);
        margin: 0 0 18px;
        line-height: 1.6;
      }
      .dlg-row {
        display: flex;
        gap: 10px;
      }
      .dlg-row button {
        flex: 1 1 0;
        height: 46px;
        border-radius: 13px;
        font-size: 14px;
        font-weight: 700;
      }
      .dlg-cancel {
        background: #f2f4fa;
        color: var(--ink-2);
      }
      .dlg-ok {
        background: var(--blue);
        color: #fff;
      }
      .dlg-ok.is-danger {
        background: var(--danger);
      }

      /* ===================================================================
         LOGIN
         =================================================================== */
      .login {
        min-height: 100dvh;
        display: grid;
        place-items: center;
        padding: 24px;
      }
      .login-card {
        width: 100%;
        max-width: 380px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--r-lg);
        padding: 30px 24px;
        box-shadow: var(--shadow-pop);
        text-align: center;
      }
      .login-logo {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: var(--blue);
        color: #fff;
        display: grid;
        place-items: center;
        margin: 0 auto 16px;
        font-size: 24px;
        font-weight: 900;
      }
      .login-t {
        font-size: 19px;
        font-weight: 900;
        margin: 0 0 4px;
      }
      .login-s {
        font-size: 13px;
        color: var(--ink-3);
        margin: 0 0 22px;
      }
      .login-card .input {
        text-align: center;
        margin-bottom: 12px;
      }
      .login-btn {
        width: 100%;
        height: 50px;
        border-radius: var(--r-md);
        font-size: 15px;
        font-weight: 700;
        color: #fff;
        background: var(--blue);
        box-shadow: 0 6px 18px var(--blue-ring);
        transition: transform 0.1s, opacity 0.15s;
      }
      .login-btn:active {
        transform: scale(0.98);
      }
      .login-btn[disabled] {
        opacity: 0.6;
        pointer-events: none;
      }
      .login-err {
        margin: 12px 0 0;
        font-size: 13px;
        font-weight: 600;
        color: var(--danger);
      }

      .hidden {
        display: none !important;
      }

      /* ===================================================================
         DESKTOP — 同じ1カラムUIを中央寄せで上品に
         =================================================================== */
      @media (min-width: 720px) {
        .home-card {
          padding: 18px 20px;
        }
        .pv-logos {
          grid-template-columns: repeat(4, 1fr);
        }
      }

      /* ===================================================================
         DESKTOP 3-PANE — WP-admin風ダークナビ (≥1024px)
         カラートークン:
           --nav-bg:    #1e2330  ダークネイビーサイドバー
           --nav-border:#2a3147  サイドバー内セパレータ
           --nav-text:  rgba(255,255,255,0.65)  非アクティブ文字
           --nav-active:#2563eb  アクティブブルー
           --hdr-bg:    #141922  最暗トップバー
         =================================================================== */
      :root {
        --nav-bg:    #1e2330;
        --nav-border:#2a3147;
        --nav-text:  rgba(255,255,255,0.65);
        --nav-active:#1463ff;
        --hdr-bg:    #141922;
      }

      .app-desktop {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        overflow: hidden;
        background: #f0f2f7;
      }

      /* --- Top bar -------------------------------------------------------- */
      .desk-header {
        flex: 0 0 auto;
        height: 46px;
        background: var(--hdr-bg);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px 0 0;
        gap: 0;
        z-index: 20;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .desk-brand {
        display: flex;
        align-items: center;
        height: 100%;
        padding: 0 20px;
        gap: 10px;
        border-right: 1px solid rgba(255,255,255,0.07);
        /* matches sidebar width */
        width: 220px;
        flex: 0 0 auto;
      }
      .desk-brand-ico {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        background: var(--nav-active);
        color: #fff;
        font-size: 13px;
        font-weight: 900;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
      }
      .desk-brand-name {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: rgba(255,255,255,0.88);
        white-space: nowrap;
      }
      .desk-header-right {
        display: flex;
        align-items: center;
        gap: 4px;
        margin-left: auto;
      }
      .desk-site-link {
        font-size: 12.5px;
        font-weight: 600;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        padding: 5px 11px;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.14);
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        white-space: nowrap;
      }
      .desk-site-link:hover {
        color: #fff;
        border-color: rgba(255,255,255,0.38);
        background: rgba(255,255,255,0.06);
      }
      .desk-logout {
        font-size: 12.5px;
        font-weight: 600;
        color: rgba(255,255,255,0.45);
        background: none;
        border: none;
        cursor: pointer;
        padding: 5px 11px;
        border-radius: 6px;
        font-family: inherit;
        transition: color 0.15s, background 0.15s;
        white-space: nowrap;
      }
      .desk-logout:hover {
        color: #fff;
        background: rgba(255,255,255,0.08);
      }
      .desk-body {
        flex: 1 1 auto;
        display: flex;
        overflow: hidden;
      }

      /* --- Dark sidebar (WP-admin style) ---------------------------------- */
      .desk-sidebar {
        flex: 0 0 220px;
        width: 220px;
        background: var(--nav-bg);
        overflow-y: auto;
        overflow-x: hidden;
        padding: 10px 0 24px;
        display: flex;
        flex-direction: column;
        gap: 1px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.1) transparent;
      }
      .desk-sidebar::-webkit-scrollbar { width: 4px; }
      .desk-sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

      /* sidebar section label */
      .side-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.42);
        padding: 14px 18px 5px;
        text-transform: uppercase;
      }

      .side-tab {
        display: flex;
        align-items: center;
        gap: 0;
        width: 100%;
        padding: 0;
        border: none;
        background: none;
        cursor: pointer;
        text-align: left;
        color: var(--nav-text);
        font-family: inherit;
        position: relative;
        transition: color 0.13s;
      }
      .side-tab-inner {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 9px 16px 9px 14px;
        border-left: 3px solid transparent;
        transition: background 0.13s, border-color 0.13s;
      }
      .side-tab:hover .side-tab-inner {
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.9);
      }
      .side-tab:hover {
        color: rgba(255,255,255,0.9);
      }
      .side-tab.is-active {
        color: #fff;
      }
      .side-tab.is-active .side-tab-inner {
        background: rgba(20,99,255,0.22);
        border-left-color: var(--nav-active);
      }
      .side-tab-ico {
        flex: 0 0 auto;
        width: 28px;
        height: 28px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: transparent;
        overflow: visible;
      }
      .side-tab-ico img { filter: drop-shadow(0 2px 4px rgba(0,0,0,0.35)); }
      .side-tab-tx {
        flex: 1 1 auto;
        min-width: 0;
      }
      .side-tab-name {
        font-size: 13px;
        font-weight: 600;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.3;
      }
      .side-tab-meta {
        font-size: 11px;
        display: block;
        margin-top: 1px;
        color: rgba(255,255,255,0.55);
        font-weight: 500;
      }
      .side-tab.is-active .side-tab-meta {
        color: rgba(255,255,255,0.55);
      }

      /* --- Center pane ---------------------------------------------------- */
      .desk-center {
        flex: 1 1 auto;
        min-width: 0;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        background: #f0f2f7;
      }
      /* sub-header inside center (title + save) */
      .desk-center-head {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 13px 22px;
        background: #fff;
        border-bottom: 1px solid var(--line);
        box-shadow: 0 1px 3px rgba(16,23,38,0.06);
      }
      .desk-center-title {
        font-size: 15px;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--ink);
      }
      .desk-title-ico {
        flex: 0 0 auto;
        width: 26px;
        height: 26px;
        display: grid;
        place-items: center;
        border-radius: 7px;
        background: var(--blue-soft);
        overflow: hidden;
      }
      .desk-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 12.5px;
        font-weight: 700;
        color: var(--blue);
        background: var(--blue-soft);
        border: none;
        border-radius: 999px;
        padding: 5px 13px 5px 8px;
        cursor: pointer;
        font-family: inherit;
        transition: background 0.13s, transform 0.1s;
      }
      .desk-back-btn:active { transform: scale(0.96); }
      .desk-back-btn svg { width: 14px; height: 14px; }
      .desk-save-btn {
        flex: 0 0 auto;
        height: 34px;
        padding: 0 18px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        background: var(--blue);
        border: none;
        cursor: pointer;
        font-family: inherit;
        box-shadow: 0 2px 8px var(--blue-ring);
        transition: transform 0.1s, opacity 0.15s, background 0.15s;
      }
      .desk-save-btn:hover { background: var(--blue-dark); }
      .desk-save-btn:active { transform: scale(0.96); }
      .desk-save-btn[disabled] { opacity: 0.5; pointer-events: none; box-shadow: none; }
      /* scrollable body area inside center */
      .desk-center-body {
        flex: 1 1 auto;
        padding: 22px 24px 48px;
        overflow-y: auto;
        max-width: 740px;
        margin-inline: auto;
        width: 100%;
      }
      /* center list top bar */
      .desk-list-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
      }
      .desk-section-desc {
        font-size: 13px;
        color: var(--ink-3);
        margin: 0;
      }

      /* --- Right preview pane -------------------------------------------- */
      .desk-preview {
        flex: 0 0 360px;
        min-width: 300px;
        max-width: 420px;
        border-left: 1px solid var(--line);
        background: #e8ecf4;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .desk-pv-head {
        flex: 0 0 auto;
        padding: 11px 16px 10px;
        border-bottom: 1px solid var(--line);
        background: #fff;
        display: flex;
        align-items: baseline;
        gap: 8px;
      }
      .desk-pv-label {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--blue);
        margin: 0;
        text-transform: uppercase;
      }
      .desk-pv-note {
        font-size: 11px;
        color: var(--ink-3);
        margin: 0;
      }
      .desk-pv-body {
        flex: 1 1 auto;
        padding: 16px 14px 30px;
        overflow-y: auto;
      }
      .desk-pv-empty {
        color: var(--ink-3);
        font-size: 13px;
        text-align: center;
        padding: 48px 16px;
      }

      @media (max-width: 1200px) {
        .desk-preview { flex: 0 0 320px; min-width: 280px; }
        .desk-sidebar { flex: 0 0 200px; width: 200px; }
        .desk-brand  { width: 200px; }
      }
      @media (max-width: 1023px) {
        /* hide desktop layout; mobile layout shown instead */
        .app-desktop { display: none !important; }
      }
    </style>
  </head>

  <body>
    <!-- LOGIN -->
    <div id="login" class="login">
      <form id="loginForm" class="login-card" autocomplete="off">
        <div class="login-logo">S</div>
        <h1 class="login-t">SellPro 管理</h1>
        <p class="login-s">パスワードを入力してください</p>
        <input
          id="loginPw"
          class="input"
          type="password"
          inputmode="text"
          placeholder="パスワード"
          aria-label="管理パスワード"
          autocomplete="current-password"
        />
        <button id="loginBtn" class="login-btn" type="submit">ログイン</button>
        <p id="loginErr" class="login-err hidden" role="alert" aria-live="assertive"></p>
      </form>
    </div>

    <!-- APP (mobile mode) -->
    <div id="app" class="app hidden">
      <header class="bar">
        <div class="bar-inner">
          <div id="barLeft" class="bar-slot" style="justify-content:flex-start"></div>
          <div id="barTitle" class="bar-title">コンテンツ</div>
          <div id="barRight" class="bar-slot"></div>
        </div>
      </header>
      <main class="main">
        <div id="view" class="wrap"></div>
      </main>
    </div>

    <!-- HAMBURGER DRAWER (mobile only) -->
    <div id="hamScrim" class="ham-scrim" aria-hidden="true"></div>
    <div id="hamDrawer" class="ham-drawer" role="dialog" aria-modal="true" aria-label="セクションメニュー">
      <div class="ham-drawer-head">
        <span class="ham-drawer-brand-ico">S</span>
        <span class="ham-drawer-brand-name">SELLPRO CMS</span>
        <button id="hamClose" class="ham-drawer-close" type="button" aria-label="メニューを閉じる">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <nav id="hamNav" class="ham-drawer-nav" aria-label="コンテンツセクション"></nav>
    </div>

    <!-- APP DESKTOP (3-pane, hidden on mobile) -->
    <div id="appDesktop" class="app-desktop hidden">
      <header class="desk-header">
        <div class="desk-brand">
          <span class="desk-brand-ico">S</span>
          <span class="desk-brand-name">SELLPRO CMS</span>
        </div>
        <div class="desk-header-right">
          <a id="deskSiteLink" href="https://sellpro-lp.vercel.app/" target="_blank" rel="noopener noreferrer" class="desk-site-link">本番を確認 ↗</a>
          <button id="deskLogout" class="desk-logout" type="button">ログアウト</button>
        </div>
      </header>
      <div class="desk-body">
        <nav id="deskSidebar" class="desk-sidebar" aria-label="セクション"></nav>
        <main id="deskCenter" class="desk-center"></main>
        <aside id="deskPreview" class="desk-preview" aria-label="プレビュー"></aside>
      </div>
    </div>

    <!-- OVERLAY / TOAST / DIALOG mount points -->
    <div id="overlay"></div>
    <div id="toast" class="toast" role="status" aria-live="polite"></div>
    <div id="dlgBack" class="dlg-back" role="dialog" aria-modal="true" aria-labelledby="dlgT">
      <div class="dlg">
        <h2 id="dlgT" class="dlg-t"></h2>
        <p id="dlgM" class="dlg-m"></p>
        <div class="dlg-row">
          <button id="dlgCancel" class="dlg-cancel" type="button">キャンセル</button>
          <button id="dlgOk" class="dlg-ok" type="button">OK</button>
        </div>
      </div>
    </div>

    <script>
      // =====================================================================
      // CONST
      // =====================================================================
      const PW_STORE_KEY = "sellpro_admin_pw";
      const ASSET_BASE = "https://sellpro-lp.vercel.app/";
      const SITE_URL = "https://sellpro-lp.vercel.app/";
      const API_CONTENT = "/api/admin-content";
      const API_UPLOAD = "/api/admin-upload";

      // 種別メタ。key=API キー、folder=アップロード先、kind=array|object
      const SECTIONS = {
        banner: {
          key: "banner", kind: "object", folder: "banner",
          icon: "📢", iconFile: "/admin-icons/icon-banner.png", name: "バナー",
          desc: "画面下に出る案内バナー",
        },
        docs: {
          key: "docs", kind: "array", folder: "docs",
          icon: "📄", iconFile: "/admin-icons/icon-docs.png", name: "ダウンロード資料",
          desc: "資料ページに並ぶPDF",
        },
        interviews: {
          key: "interviews", kind: "array", folder: "product",
          icon: "💬", iconFile: "/admin-icons/icon-interviews.png", name: "導入インタビュー",
          desc: "お客様の声・Q&A",
        },
        logos: {
          key: "logos", kind: "array", folder: "logos",
          icon: "🏢", iconFile: "/admin-icons/icon-logos.png", name: "導入企業ロゴ",
          desc: "トップに並ぶ企業ロゴ",
        },
        faqs: {
          key: "faqs", kind: "array", folder: null,
          icon: "❓", iconFile: "/admin-icons/icon-faq.png", name: "よくある質問",
          desc: "FAQ セクション",
        },
      };
      const SECTION_ORDER = ["banner", "docs", "interviews", "logos", "faqs"];

      // セクションアイコン <img> を生成するヘルパ
      // size: ピクセル数(正方形)
      const secIconImg = (sec, size) => {
        const img = document.createElement('img');
        img.src = sec.iconFile;
        img.alt = '';
        img.width = size;
        img.height = size;
        img.style.cssText = `width:${size}px;height:${size}px;object-fit:contain;display:block;`;
        img.onerror = () => { img.replaceWith(document.createTextNode(sec.icon)); };
        return img;
      };

      // =====================================================================
      // STATE
      // =====================================================================
      const state = {
        password: "",
        view: "home",        // home | list | edit
        sectionId: null,     // 現在の種別
        store: {},           // key -> { data, sha }
        draft: null,         // 編集中アイテムのコピー
        draftIndex: null,    // 配列内 index（新規は null）
        loading: false,
        saving: false,
        // M3: 編集フォーム中のアップロード直後ObjectURL保持
        // field識別子("banner.image" / "avatar" / "logo") -> ObjectURL
        localUrls: {},
        _draftSnapshot: null,  // dirty検知スナップショット
      };

      const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

      // Preview refresh (debounced via rAF for live preview on desktop)
      let _pvRafId = null;
      function schedulePreviewRefresh() {
        // 保存ボタンの活性状態を即時更新
        const saveBtn = document.querySelector('.desk-save-btn');
        if (saveBtn && !state.saving) {
          if (isDirty()) saveBtn.removeAttribute('disabled');
          else saveBtn.setAttribute('disabled', '');
        }
        const barSave = document.querySelector('.bar-save');
        if (barSave && !state.saving) {
          if (isDirty()) barSave.removeAttribute('disabled');
          else barSave.setAttribute('disabled', '');
        }
        if (!isDesktop() || !state.draft) return;
        if (_pvRafId) cancelAnimationFrame(_pvRafId);
        _pvRafId = requestAnimationFrame(() => { _pvRafId = null; renderDesktopPreview(); });
      }

      // =====================================================================
      // UTIL
      // =====================================================================
      const $ = (id) => document.getElementById(id);
      const el = (tag, attrs = {}, children = []) => {
        const node = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (k === "class") node.className = v;
          else if (k === "html") node.innerHTML = v;
          else if (k === "text") node.textContent = v;
          else if (k.startsWith("on") && typeof v === "function")
            node.addEventListener(k.slice(2).toLowerCase(), v);
          else if (v !== null && v !== false && v !== undefined)
            node.setAttribute(k, v === true ? "" : v);
        }
        (Array.isArray(children) ? children : [children]).forEach((c) => {
          if (c == null || c === false) return;
          node.appendChild(typeof c === "string" ? document.createTextNode(c) : c);
        });
        return node;
      };
      const esc = (s) =>
        String(s ?? "")
          .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;").replace(/'/g, "&#39;");

      // 画像参照の絶対URL化（規約に合わせる）
      const assetUrl = (path) => {
        if (!path) return "";
        if (/^https?:\/\//.test(path)) return path;
        return ASSET_BASE + String(path).replace(/^\/+/, "");
      };
      const logoUrl = (file) => (file ? ASSET_BASE + "logos/" + String(file).replace(/^\/+/, "") : "");

      // M3: ローカルObjectURL優先解決。fieldKey に対応するURLがあればそれを返す
      const resolveImgUrl = (fieldKey, stored, isLogo) => {
        if (state.localUrls[fieldKey]) return state.localUrls[fieldKey];
        return isLogo ? logoUrl(stored) : assetUrl(stored);
      };

      // フォームを離れるとき・ログアウト時に全ObjectURLを破棄
      function revokeAllLocalUrls() {
        Object.values(state.localUrls).forEach((u) => { try { URL.revokeObjectURL(u); } catch (_) {} });
        state.localUrls = {};
      }

      const sanitizeFilename = (name) => {
        const dot = name.lastIndexOf(".");
        let base = dot > 0 ? name.slice(0, dot) : name;
        let ext = dot > 0 ? name.slice(dot + 1) : "";
        base = base.replace(/[^A-Za-z0-9._-]/g, "-").replace(/-+/g, "-").replace(/^[.\-]+|[.\-]+$/g, "");
        ext = ext.replace(/[^A-Za-z0-9]/g, "").toLowerCase();
        if (!base) base = "file";
        return ext ? `${base}-${Date.now()}.${ext}` : `${base}-${Date.now()}`;
      };
      const fileToBase64 = (file) =>
        new Promise((resolve, reject) => {
          const r = new FileReader();
          r.onload = () => resolve(String(r.result).split(",")[1] || "");
          r.onerror = reject;
          r.readAsDataURL(file);
        });

      const ICON = {
        chev: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>',
        back: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>',
        plus: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>',
        edit: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg>',
        trash: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>',
        up: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M17 8l-5-5-5 5"/><path d="M12 3v12"/></svg>',
        eye: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>',
        x: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>',
        arrowUp: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>',
        arrowDown: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>',
        check: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>',
      };

      // =====================================================================
      // TOAST / DIALOG
      // =====================================================================
      let toastTimer = null;
      const toast = (msg, opts = {}) => {
        const t = $("toast");
        t.innerHTML = "";
        if (opts.icon !== false) t.appendChild(el("span", { html: ICON.check }));
        t.appendChild(el("span", { html: msg })); // msg はこちらで生成・エスケープ済み
        const closeBtn = el('button', {
          type: 'button',
          style: 'background:none;border:none;color:rgba(255,255,255,0.7);font-size:16px;cursor:pointer;padding:0 0 0 8px;line-height:1;flex-shrink:0',
          text: '✕',
          onClick: () => { t.classList.remove('show'); clearTimeout(toastTimer); }
        });
        t.appendChild(closeBtn);
        t.classList.toggle("is-err", !!opts.error);
        t.classList.add("show");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => t.classList.remove("show"), opts.duration || 4200);
      };

      const confirmDialog = ({ title, message, okLabel = "OK", danger = false }) =>
        new Promise((resolve) => {
          const back = $("dlgBack");
          $("dlgT").textContent = title;
          $("dlgM").textContent = message;
          const ok = $("dlgOk");
          ok.textContent = okLabel;
          ok.classList.toggle("is-danger", danger);
          back.classList.add("show");
          const done = (val) => {
            back.classList.remove("show");
            ok.removeEventListener("click", onOk);
            $("dlgCancel").removeEventListener("click", onCancel);
            back.removeEventListener("click", onBack);
            resolve(val);
          };
          const onOk = () => done(true);
          const onCancel = () => done(false);
          const onBack = (e) => { if (e.target === back) done(false); };
          ok.addEventListener("click", onOk);
          $("dlgCancel").addEventListener("click", onCancel);
          back.addEventListener("click", onBack);
        });

      // =====================================================================
      // HAMBURGER DRAWER (mobile only)
      // =====================================================================
      let _hamTriggerEl = null; // フォーカス復帰先

      function renderHamNav() {
        const nav = $('hamNav');
        if (!nav) return;
        nav.innerHTML = '';
        // section label
        nav.appendChild(el('p', { class: 'ham-section-label', text: 'コンテンツ' }));
        SECTION_ORDER.forEach(sid => {
          const sec = SECTIONS[sid];
          const entry = state.store[sec.key];
          let metaTxt = '';
          if (state.loading || !entry) {
            metaTxt = '…';
          } else if (sec.kind === 'object') {
            metaTxt = entry.data?.enabled ? '表示中' : '非表示';
          } else {
            metaTxt = `${Array.isArray(entry.data) ? entry.data.length : 0}件`;
          }
          const isActive = state.sectionId === sid;
          const tab = el('button', {
            class: 'ham-tab' + (isActive ? ' is-active' : ''),
            type: 'button',
            'aria-current': isActive ? 'page' : 'false',
            onClick: () => switchSectionFromDrawer(sid),
          }, [
            el('div', { class: 'ham-tab-inner' }, [
              el('span', { class: 'ham-tab-ico' }, [secIconImg(sec, 22)]),
              el('span', { class: 'ham-tab-tx' }, [
                el('span', { class: 'ham-tab-name', text: sec.name }),
                el('span', { class: 'ham-tab-meta', text: metaTxt }),
              ]),
            ]),
          ]);
          nav.appendChild(tab);
        });
      }

      async function switchSectionFromDrawer(sid) {
        // dirty check: 編集中に未保存があれば確認
        if (state.view === 'edit' && isDirty()) {
          const ok = await confirmDialog({
            title: '編集をやめますか？',
            message: '保存していない変更は反映されません。',
            okLabel: '編集をやめる', danger: true,
          });
          if (!ok) return;
          revokeAllLocalUrls();
        } else if (state.view === 'edit') {
          revokeAllLocalUrls();
        }
        closeDrawer();
        state.sectionId = sid;
        openSection(sid);
      }

      function openDrawer() {
        const drawer = $('hamDrawer');
        const scrim = $('hamScrim');
        if (!drawer || !scrim) return;
        _hamTriggerEl = document.activeElement; // フォーカス復帰先を記憶
        renderHamNav();
        drawer.classList.add('is-open');
        scrim.classList.add('is-open');
        scrim.removeAttribute('aria-hidden');
        // スクロールロック
        document.body.style.overflow = 'hidden';
        // フォーカストラップ: ドロワー内最初のフォーカス可能要素にフォーカス
        const focusable = drawer.querySelectorAll('button, [href], input, [tabindex]:not([tabindex="-1"])');
        if (focusable.length) focusable[0].focus();
        // キーハンドラ
        document.addEventListener('keydown', _onDrawerKey);
      }

      function closeDrawer() {
        const drawer = $('hamDrawer');
        const scrim = $('hamScrim');
        if (!drawer || !scrim) return;
        drawer.classList.remove('is-open');
        scrim.classList.remove('is-open');
        scrim.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        document.removeEventListener('keydown', _onDrawerKey);
        // トリガへフォーカス復帰
        if (_hamTriggerEl && typeof _hamTriggerEl.focus === 'function') {
          try { _hamTriggerEl.focus(); } catch (_) {}
        }
        _hamTriggerEl = null;
      }

      function _onDrawerKey(e) {
        const drawer = $('hamDrawer');
        if (!drawer) return;
        if (e.key === 'Escape') {
          e.preventDefault();
          closeDrawer();
          return;
        }
        // フォーカストラップ (Tab / Shift+Tab)
        if (e.key === 'Tab') {
          const focusable = Array.from(drawer.querySelectorAll(
            'button:not([disabled]), [href], input:not([disabled]), [tabindex]:not([tabindex="-1"])'
          )).filter(el => el.offsetParent !== null);
          if (!focusable.length) { e.preventDefault(); return; }
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey) {
            if (document.activeElement === first) { e.preventDefault(); last.focus(); }
          } else {
            if (document.activeElement === last) { e.preventDefault(); first.focus(); }
          }
        }
      }

      // スクリム・閉じるボタンのイベント登録（スクリプトは body 末尾なので即時実行可）
      (() => {
        const scrim = $('hamScrim');
        if (scrim) scrim.addEventListener('click', closeDrawer);
        const closeBtn = $('hamClose');
        if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
      })();

      // =====================================================================
      // API（既存 admin-content・契約どおり）
      // =====================================================================
      async function apiGet(key) {
        const res = await fetch(`${API_CONTENT}?key=${encodeURIComponent(key)}`, {
          headers: { "X-Admin-Password": state.password },
        });
        if (res.status === 401) { logout(); throw new Error("パスワードが正しくありません。"); }
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error || "読み込みに失敗しました。");
        return body; // { path, sha, data }
      }
      async function apiSave(key, data, sha, message) {
        const res = await fetch(`${API_CONTENT}?key=${encodeURIComponent(key)}`, {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-Admin-Password": state.password },
          body: JSON.stringify({ data, sha, message }),
        });
        if (res.status === 401) { logout(); throw new Error("パスワードが正しくありません。"); }
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error || "保存に失敗しました。");
        return body; // { path, sha, data }
      }

      // =====================================================================
      // UPLOAD（admin-upload・契約どおり）
      // 返り値: { path, rawPath }
      // =====================================================================
      async function uploadFile(folder, file) {
        const filename = sanitizeFilename(file.name || "upload");
        const contentBase64 = await fileToBase64(file);
        const res = await fetch(`${API_UPLOAD}?folder=${encodeURIComponent(folder)}`, {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-Admin-Password": state.password },
          body: JSON.stringify({ filename, contentBase64, message: `Upload ${folder}/${filename}` }),
        });
        if (res.status === 401) { logout(); throw new Error("パスワードが正しくありません。"); }
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body.error || "アップロードに失敗しました。");
        return body;
      }

      // =====================================================================
      // BAR — タイトル / 戻る / 保存 を状態から描画
