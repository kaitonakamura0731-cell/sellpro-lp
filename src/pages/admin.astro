---
// SellPro 管理ページ
// GitHub トークンはブラウザに持たせず、/api/admin-content 経由でサーバー側から更新する。
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>SellPro 管理ページ</title>
    <style>
      :root {
        --blue: #1c6fd2;
        --blue-dark: #1358ac;
        --blue-soft: #eaf2fc;
        --ink: #17243a;
        --muted: #68778d;
        --line: #d8e3f1;
        --bg: #f5f8fc;
        --card: #ffffff;
        --danger: #c33a2b;
        --ok: #147a4b;
        --radius: 12px;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        min-width: 320px;
        background: var(--bg);
        color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans",
          "Hiragino Kaku Gothic ProN", "Noto Sans JP", Meiryo, sans-serif;
        font-size: 15px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; }

      .wrap {
        width: min(1080px, 100%);
        margin: 0 auto;
        padding: 28px 18px 72px;
      }

      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 22px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--line);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
      }

      .mark {
        width: 34px;
        height: 34px;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
        border-radius: 10px;
        background: var(--blue);
        color: #fff;
        font-weight: 800;
      }

      h1 {
        margin: 0;
        font-size: 21px;
        line-height: 1.35;
        letter-spacing: 0;
      }

      .sub {
        color: var(--muted);
        font-size: 12.5px;
      }

      .links {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 8px;
      }

      .links a,
      button {
        border: 1px solid transparent;
        border-radius: 999px;
        font: inherit;
        font-weight: 700;
        text-decoration: none;
      }

      .links a {
        padding: 8px 13px;
        border-color: var(--line);
        background: #fff;
        color: var(--blue-dark);
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: 0 18px 44px rgba(22, 51, 95, .08);
      }

      .login {
        max-width: 620px;
        padding: 22px;
      }

      .login h2,
      .editor-head h2 {
        margin: 0;
        font-size: 18px;
        line-height: 1.45;
      }

      .lead {
        margin: 7px 0 18px;
        color: var(--muted);
        font-size: 13px;
      }

      label {
        display: grid;
        gap: 7px;
        font-weight: 700;
        font-size: 13px;
      }

      input,
      textarea {
        width: 100%;
        border: 1px solid #c9d5e4;
        border-radius: 10px;
        background: #fff;
        color: var(--ink);
        font: inherit;
        padding: 11px 12px;
        outline: none;
      }

      textarea {
        min-height: 500px;
        resize: vertical;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", "Courier New", monospace;
        font-size: 13px;
        line-height: 1.65;
      }

      input:focus,
      textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(28, 111, 210, .14);
      }

      button {
        appearance: none;
        -webkit-appearance: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 42px;
        padding: 10px 18px;
        color: #fff;
        background: var(--blue);
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(28, 111, 210, .2);
      }

      button:hover { background: var(--blue-dark); }
      button:disabled {
        cursor: not-allowed;
        opacity: .58;
        box-shadow: none;
      }

      .ghost {
        border-color: var(--line);
        background: #fff;
        color: var(--blue-dark);
        box-shadow: none;
      }

      .ghost:hover {
        background: var(--blue-soft);
      }

      .danger {
        color: var(--danger);
      }

      .ok {
        color: var(--ok);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        margin-top: 16px;
      }

      .status {
        min-height: 22px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 700;
      }

      .workspace {
        display: none;
        grid-template-columns: 260px minmax(0, 1fr);
        gap: 18px;
      }

      .workspace.is-ready {
        display: grid;
      }

      .side {
        padding: 12px;
        align-self: start;
      }

      .file-tabs {
        display: grid;
        gap: 8px;
      }

      :global(.tab) {
        width: 100%;
        appearance: none;
        -webkit-appearance: none;
        display: inline-flex;
        min-height: auto;
        justify-content: flex-start;
        border: 1px solid transparent;
        border-radius: 10px;
        padding: 11px 12px;
        background: transparent;
        color: var(--ink);
        font: inherit;
        font-weight: 700;
        box-shadow: none;
        text-align: left;
        cursor: pointer;
      }

      :global(.tab:hover),
      :global(.tab.is-active) {
        background: var(--blue-soft);
        color: var(--blue-dark);
      }

      :global(.tab-title) {
        display: block;
        font-size: 13px;
        line-height: 1.35;
      }

      :global(.tab-sub) {
        display: block;
        margin-top: 2px;
        color: var(--muted);
        font-size: 11.5px;
        font-weight: 600;
        line-height: 1.35;
      }

      .editor {
        min-width: 0;
        padding: 20px;
      }

      .editor-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 16px;
      }

      .pill {
        flex: 0 0 auto;
        max-width: 100%;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 10px;
        background: #fff;
        color: var(--muted);
        font-size: 12px;
        font-weight: 700;
        line-height: 1.35;
        overflow-wrap: anywhere;
      }

      .meta {
        display: grid;
        gap: 4px;
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 12px;
      }

      .empty {
        padding: 24px;
        color: var(--muted);
        text-align: center;
      }

      .is-hidden { display: none !important; }

      @media (max-width: 760px) {
        .wrap { padding: 18px 14px 56px; }

        .header {
          align-items: flex-start;
          flex-direction: column;
        }

        .links {
          justify-content: flex-start;
        }

        .login,
        .editor {
          padding: 18px;
        }

        .workspace.is-ready {
          display: grid;
          grid-template-columns: 1fr;
        }

        .side {
          position: static;
        }

        .file-tabs {
          grid-template-columns: 1fr 1fr;
        }

        .editor-head {
          flex-direction: column;
        }

        textarea {
          min-height: 420px;
          font-size: 12.5px;
        }

        button {
          flex: 1 1 150px;
        }
      }

      @media (max-width: 420px) {
        .file-tabs {
          grid-template-columns: 1fr;
        }

        .links a,
        button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="header">
        <div class="brand">
          <div class="mark">S</div>
          <div>
            <h1>SellPro 管理ページ</h1>
            <div class="sub">本番コンテンツ更新</div>
          </div>
        </div>
        <nav class="links" aria-label="関連リンク">
          <a href="/">サイトを見る</a>
          <a href="/docs/">資料ページ</a>
          <a href="/contact/">お問い合わせ</a>
        </nav>
      </header>

      <section class="card login" id="loginCard">
        <h2>管理パスワード</h2>
        <p class="lead">
          パスワードを入れるだけで、更新データを開けます。保存後は本番反映まで自動で進みます。
        </p>
        <label>
          パスワード
          <input
            id="passwordInput"
            type="password"
            autocomplete="current-password"
            placeholder="管理パスワードを入力"
          />
        </label>
        <div class="actions">
          <button id="connectButton" type="button">開く</button>
          <span class="status" id="loginStatus"></span>
        </div>
      </section>

      <main class="workspace" id="workspace">
        <aside class="card side" aria-label="編集対象">
          <div class="file-tabs" id="fileTabs"></div>
        </aside>

        <section class="card editor">
          <div id="emptyState" class="empty">読み込み中です。</div>
          <div id="editorPanel" class="is-hidden">
            <div class="editor-head">
              <div>
                <h2 id="editorTitle"></h2>
                <div class="lead" id="editorDescription"></div>
              </div>
              <div class="pill" id="editorPath"></div>
            </div>
            <div class="meta">
              <span id="editorSha">commit: -</span>
              <span>保存後、数分で本番ページに反映されます。</span>
            </div>
            <textarea id="editorText" spellcheck="false"></textarea>
            <div class="actions">
              <button id="saveButton" type="button">保存する</button>
              <button id="formatButton" class="ghost" type="button">整える</button>
              <button id="reloadButton" class="ghost" type="button">再読み込み</button>
              <span class="status" id="editorStatus"></span>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script>
      const files = [
        {
          key: "banner",
          title: "バナー",
          description: "常時表示バナーのON/OFF、画像、リンク",
        },
        {
          key: "docs",
          title: "資料",
          description: "資料一覧ページのPDF・準備中表示",
        },
        {
          key: "interviews",
          title: "インタビュー",
          description: "導入インタビューの会社情報・Q&A",
        },
        {
          key: "logos",
          title: "ロゴ",
          description: "導入企業ロゴと確認中バッジ",
        },
        {
          key: "faqs",
          title: "FAQ",
          description: "トップページFAQと構造化データ",
        },
      ];

      const state = {
        password: sessionStorage.getItem("sellproAdminPassword") || "",
        activeKey: files[0].key,
        records: {},
      };

      const $ = (id) => document.getElementById(id);

      const loginCard = $("loginCard");
      const workspace = $("workspace");
      const fileTabs = $("fileTabs");
      const loginStatus = $("loginStatus");
      const editorStatus = $("editorStatus");
      const emptyState = $("emptyState");
      const editorPanel = $("editorPanel");
      const editorText = $("editorText");

      $("passwordInput").value = state.password;

      function setStatus(target, message, type = "") {
        target.textContent = message || "";
        target.classList.toggle("danger", type === "danger");
        target.classList.toggle("ok", type === "ok");
      }

      function pretty(value) {
        return JSON.stringify(value, null, 2) + "\n";
      }

      async function requestContent(key, options = {}) {
        const response = await fetch(`/api/admin-content?key=${encodeURIComponent(key)}`, {
          method: options.method || "GET",
          headers: {
            "Content-Type": "application/json",
            "X-Admin-Password": state.password,
          },
          body: options.body ? JSON.stringify(options.body) : undefined,
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || "通信に失敗しました。");
        }
        return payload;
      }

      function renderTabs() {
        fileTabs.innerHTML = files.map((file) => {
          const record = state.records[file.key];
          const status = record ? "読み込み済み" : "未読込";
          return `
            <button class="tab ${file.key === state.activeKey ? "is-active" : ""}" type="button" data-key="${file.key}">
              <span class="tab-title">${file.title}</span>
              <span class="tab-sub">${status}</span>
            </button>
          `;
        }).join("");

        fileTabs.querySelectorAll("button").forEach((button) => {
          button.addEventListener("click", () => {
            state.activeKey = button.dataset.key;
            renderTabs();
            renderEditor();
          });
        });
      }

      function renderEditor() {
        const file = files.find((item) => item.key === state.activeKey);
        const record = state.records[state.activeKey];

        if (!record) {
          emptyState.classList.remove("is-hidden");
          editorPanel.classList.add("is-hidden");
          emptyState.textContent = `${file.title}を読み込んでいます。`;
          return;
        }

        emptyState.classList.add("is-hidden");
        editorPanel.classList.remove("is-hidden");
        $("editorTitle").textContent = file.title;
        $("editorDescription").textContent = file.description;
        $("editorPath").textContent = record.path;
        $("editorSha").textContent = `commit: ${record.sha.slice(0, 10)}`;
        editorText.value = pretty(record.data);
        setStatus(editorStatus, "");
      }

      async function loadOne(key) {
        const payload = await requestContent(key);
        state.records[key] = payload;
        renderTabs();
        renderEditor();
      }

      async function loadAll() {
        loginCard.classList.add("is-hidden");
        workspace.classList.add("is-ready");
        renderTabs();
        renderEditor();

        for (const file of files) {
          await loadOne(file.key);
        }
      }

      async function connect() {
        state.password = $("passwordInput").value.trim();
        if (!state.password) {
          setStatus(loginStatus, "パスワードを入力してください。", "danger");
          return;
        }

        $("connectButton").disabled = true;
        setStatus(loginStatus, "確認しています。");

        try {
          sessionStorage.setItem("sellproAdminPassword", state.password);
          await loadAll();
          setStatus(loginStatus, "");
        } catch (error) {
          loginCard.classList.remove("is-hidden");
          workspace.classList.remove("is-ready");
          setStatus(loginStatus, error.message, "danger");
        } finally {
          $("connectButton").disabled = false;
        }
      }

      function parseEditor() {
        try {
          return JSON.parse(editorText.value);
        } catch (error) {
          throw new Error(`JSONの形式を確認してください: ${error.message}`);
        }
      }

      async function saveActive() {
        const key = state.activeKey;
        const file = files.find((item) => item.key === key);
        let data;

        try {
          data = parseEditor();
        } catch (error) {
          setStatus(editorStatus, error.message, "danger");
          return;
        }

        $("saveButton").disabled = true;
        setStatus(editorStatus, "保存しています。");

        try {
          const payload = await requestContent(key, {
            method: "POST",
            body: {
              data,
              sha: state.records[key]?.sha,
              message: `Update SellPro ${file.key} content`,
            },
          });
          state.records[key] = payload;
          renderTabs();
          renderEditor();
          setStatus(editorStatus, "保存しました。本番反映が始まります。", "ok");
        } catch (error) {
          setStatus(editorStatus, error.message, "danger");
        } finally {
          $("saveButton").disabled = false;
        }
      }

      function formatActive() {
        try {
          editorText.value = pretty(parseEditor());
          setStatus(editorStatus, "整えました。", "ok");
        } catch (error) {
          setStatus(editorStatus, error.message, "danger");
        }
      }

      async function reloadActive() {
        $("reloadButton").disabled = true;
        setStatus(editorStatus, "再読み込みしています。");
        try {
          await loadOne(state.activeKey);
          setStatus(editorStatus, "再読み込みしました。", "ok");
        } catch (error) {
          setStatus(editorStatus, error.message, "danger");
        } finally {
          $("reloadButton").disabled = false;
        }
      }

      $("connectButton").addEventListener("click", connect);
      $("passwordInput").addEventListener("keydown", (event) => {
        if (event.key === "Enter") connect();
      });
      $("saveButton").addEventListener("click", saveActive);
      $("formatButton").addEventListener("click", formatActive);
      $("reloadButton").addEventListener("click", reloadActive);

      if (state.password) {
        connect();
      }
    </script>
  </body>
</html>
