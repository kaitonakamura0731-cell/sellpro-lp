---
// SellPro 更新依頼ページ
// GitHub 接続や外部DBを使わず、変更内容をメールで送るだけの静的ページ。
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>SellPro 更新依頼</title>
    <style>
      :root {
        --blue: #1c6fd2;
        --blue-dark: #155bb0;
        --blue-soft: #eaf2fc;
        --ink: #18253a;
        --muted: #66758a;
        --line: #dbe5f2;
        --bg: #f5f8fc;
        --card: #ffffff;
        --radius: 14px;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans",
          "Hiragino Kaku Gothic ProN", "Noto Sans JP", Meiryo, sans-serif;
        background: var(--bg);
        color: var(--ink);
        line-height: 1.7;
        font-size: 15px;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; }

      .wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 28px 18px 80px;
      }

      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-bottom: 18px;
        border-bottom: 1px solid var(--line);
        margin-bottom: 22px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 11px;
      }

      .mark {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        display: grid;
        place-items: center;
        background: var(--blue);
        color: #fff;
        font-weight: 800;
      }

      h1 {
        margin: 0;
        font-size: 20px;
        line-height: 1.35;
      }

      .sub {
        color: var(--muted);
        font-size: 12.5px;
      }

      .links {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .links a,
      button {
        border: 1px solid transparent;
        border-radius: 999px;
        font: inherit;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
      }

      .links a {
        padding: 8px 13px;
        color: var(--blue-dark);
        background: #fff;
        border-color: var(--line);
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 22px;
        box-shadow: 0 18px 44px rgba(22, 51, 95, .08);
      }

      .lead {
        margin: 0 0 18px;
        color: var(--muted);
      }

      .notice {
        margin: 0 0 20px;
        padding: 12px 14px;
        border-radius: 10px;
        background: var(--blue-soft);
        color: var(--blue-dark);
        font-weight: 700;
        font-size: 13px;
      }

      form {
        display: grid;
        gap: 16px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      label {
        display: grid;
        gap: 6px;
        font-weight: 700;
        font-size: 13px;
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid #c9d5e4;
        border-radius: 10px;
        background: #fff;
        color: var(--ink);
        font: inherit;
        padding: 11px 12px;
        outline: none;
      }

      textarea {
        min-height: 180px;
        resize: vertical;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: var(--blue);
        box-shadow: 0 0 0 3px rgba(28, 111, 210, .14);
      }

      .hint {
        color: var(--muted);
        font-size: 12px;
        font-weight: 400;
      }

      .actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        padding-top: 4px;
      }

      button {
        padding: 12px 22px;
        color: #fff;
        background: var(--blue);
        box-shadow: 0 10px 24px rgba(28, 111, 210, .24);
      }

      button:hover { background: var(--blue-dark); }

      .mailto {
        color: var(--muted);
        font-size: 12.5px;
      }

      .quick {
        margin-top: 18px;
        display: grid;
        gap: 8px;
        color: var(--muted);
        font-size: 13px;
      }

      .quick b { color: var(--ink); }

      @media (max-width: 640px) {
        .wrap { padding-top: 18px; }
        .header {
          align-items: flex-start;
          flex-direction: column;
        }
        .links { justify-content: flex-start; }
        .card { padding: 18px; }
        .grid { grid-template-columns: 1fr; }
        button { width: 100%; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="header">
        <div class="brand">
          <div class="mark">S</div>
          <div>
            <h1>SellPro 更新依頼</h1>
            <div class="sub">シンプル更新依頼ページ</div>
          </div>
        </div>
        <nav class="links" aria-label="関連リンク">
          <a href="/">サイトを見る</a>
          <a href="/docs/">資料ページ</a>
          <a href="/contact/">お問い合わせ</a>
        </nav>
      </header>

      <main class="card">
        <p class="lead">
          バナー、資料、インタビュー、ロゴ、FAQの更新内容をここでまとめて送れます。
        </p>
        <p class="notice">
          このページはサイトを直接書き換えません。送信内容を確認してから反映します。
        </p>

        <form id="requestForm">
          <div class="grid">
            <label>
              お名前
              <input name="name" autocomplete="name" />
            </label>
            <label>
              会社名
              <input name="company" autocomplete="organization" />
            </label>
          </div>

          <div class="grid">
            <label>
              メールアドレス
              <input name="email" type="email" autocomplete="email" />
            </label>
            <label>
              更新したい箇所
              <select name="area">
                <option value="バナー">バナー</option>
                <option value="資料">資料</option>
                <option value="導入インタビュー">導入インタビュー</option>
                <option value="ロゴ">ロゴ</option>
                <option value="FAQ">FAQ</option>
                <option value="その他">その他</option>
              </select>
            </label>
          </div>

          <label>
            更新内容
            <textarea
              name="detail"
              required
              placeholder="例: FAQの1問目を差し替えたい / ロゴの確認中を外したい / バナー画像とリンクを変更したい"
            ></textarea>
            <span class="hint">画像やPDFは、共有URLを貼るか、このメールへの返信で添付してください。</span>
          </label>

          <label>
            素材URL・参考URL
            <input name="assetUrl" type="url" placeholder="https://..." />
          </label>

          <div class="actions">
            <button type="submit">更新依頼をメールで送る</button>
            <span class="mailto">送信先: geriru0099@gmail.com</span>
          </div>
        </form>

        <div class="quick">
          <div><b>急ぎの時:</b> 変更したい箇所のスクショと差し替え文面だけ送れば対応できます。</div>
          <div><b>素材がある時:</b> 画像・PDF・ロゴはメール返信で添付してもOKです。</div>
        </div>
      </main>
    </div>

    <script is:inline>
      (function () {
        var form = document.getElementById("requestForm");
        if (!form) return;

        form.addEventListener("submit", function (event) {
          event.preventDefault();
          var data = new FormData(form);
          var area = data.get("area") || "更新依頼";
          var subject = "SellProサイト更新依頼: " + area;
          var body = [
            "SellProサイト更新依頼",
            "",
            "お名前: " + (data.get("name") || ""),
            "会社名: " + (data.get("company") || ""),
            "メールアドレス: " + (data.get("email") || ""),
            "更新したい箇所: " + area,
            "素材URL・参考URL: " + (data.get("assetUrl") || ""),
            "",
            "更新内容:",
            data.get("detail") || "",
          ].join("\n");

          window.location.href =
            "mailto:geriru0099@gmail.com?subject=" +
            encodeURIComponent(subject) +
            "&body=" +
            encodeURIComponent(body);
        });
      })();
    </script>
  </body>
</html>
