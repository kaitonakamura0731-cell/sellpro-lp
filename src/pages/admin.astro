        ));
        form.appendChild(fieldUpload({
          label: "バナー画像", help: "横長の画像がおすすめです。スマホのカメラロールからも選べます。",
          folder: "banner", shape: "banner", accept: "image/*",
          value: { get: () => d.image, set: (v) => (d.image = v) },
          fieldKey: "banner.image",
        }));
        form.appendChild(fieldText(
          "画像の説明（代替テキスト）",
          "画像が表示できないときに代わりに読まれる文章です。",
          d.alt, (v) => (d.alt = v),
          { placeholder: "例: ご紹介資料 無料ダウンロード" }
        ));
        form.appendChild(fieldText(
          "リンク先", "バナーを押したときに開くページです。",
          d.link, (v) => (d.link = v), { placeholder: "例: /docs/" }
        ));
        form.appendChild(fieldToggle(
          "別のタブで開く", "オンにすると、リンクを新しいタブで開きます。",
          !!d.newTab, (v) => (d.newTab = v)
        ));
      }

      // --- 資料 --------------------------------------------------------------
      function buildDocForm(form) {
        const d = state.draft;
        form.appendChild(fieldText("資料のタイトル", "", d.title, (v) => (d.title = v),
          { placeholder: "例: SellPro ご紹介資料" }));
        form.appendChild(fieldArea("説明文", "資料ページに表示される短い説明です。",
          d.description, (v) => (d.description = v), { rows: 3, placeholder: "例: サービス概要・機能・活用事例をまとめた資料" }));
        form.appendChild(fieldUpload({
          label: "PDFファイル", help: "ダウンロードしてもらうPDFを選びます。",
          folder: "docs", shape: "pdf", accept: "application/pdf,.pdf",
          value: { get: () => d.file, set: (v) => (d.file = v) },
          fieldKey: "docs.file",
        }));
        form.appendChild(fieldText("公開する年月", "資料に添える日付です。",
          d.date, (v) => (d.date = v), { placeholder: "例: 2026-05" }));
        form.appendChild(fieldToggle("この資料を公開する",
          "オフにすると「準備中」表示になり、ダウンロードできなくなります。",
          !!d.available, (v) => (d.available = v)));
      }

      // --- インタビュー -------------------------------------------------------
      function buildInterviewForm(form) {
        const d = state.draft;
        if (!Array.isArray(d.qa)) d.qa = [];
        form.appendChild(fieldToggle("サンプルとして表示", "オンの間は「サンプル」バッジが付きます。実際の声に差し替えたらオフにしてください。",
          !!d.sample, (v) => (d.sample = v)));
        form.appendChild(fieldText("組織名・部門", "", d.org, (v) => (d.org = v),
          { placeholder: "例: メーカー業界 営業企画部門" }));
        form.appendChild(fieldText("従業員規模", "", d.scale, (v) => (d.scale = v),
          { placeholder: "例: 従業員規模 約7,000名" }));
        form.appendChild(fieldText("役職・立場", "", d.role, (v) => (d.role = v),
          { placeholder: "例: 導入ご担当者" }));
        form.appendChild(fieldUpload({
          label: "顔写真・アイコン", help: "丸く切り抜いて表示されます。",
          folder: "product", shape: "avatar", accept: "image/*",
          value: { get: () => d.avatar, set: (v) => (d.avatar = v) },
          fieldKey: "iv.avatar",
        }));

        // Q&A リピーター
        const qaWrap = el("div", { class: "field" });
        qaWrap.appendChild(el("label", { class: "field-label", text: "質問と回答" }));
        qaWrap.appendChild(el("p", { class: "field-help", text: "Q&Aは何個でも追加できます。" }));
        const block = el("div", { class: "qa-block" });
        const renderQa = () => {
          block.innerHTML = "";
          d.qa.forEach((qa, qi) => {
            const q = el("input", { class: "input", type: "text", value: qa.q ?? "", placeholder: "質問（Q）" });
            q.addEventListener("input", (e) => { qa.q = e.target.value; schedulePreviewRefresh(); });
            const a = el("textarea", { class: "textarea", rows: 3, placeholder: "回答（A）" });
            a.value = qa.a ?? "";
            a.addEventListener("input", (e) => { qa.a = e.target.value; schedulePreviewRefresh(); });
            const item = el("div", { class: "qa-item" }, [
              el("div", { class: "qa-head" }, [
                el("span", { class: "qa-no", text: `Q${qi + 1}` }),
                iconBtn(ICON.trash, "この質問を削除", () => { d.qa.splice(qi, 1); renderQa(); schedulePreviewRefresh(); }, false, true),
              ]),
              q, a,
            ]);
            block.appendChild(item);
          });
          block.appendChild(el("button", { class: "btn-line", type: "button",
            onClick: () => { d.qa.push({ q: "", a: "" }); renderQa(); schedulePreviewRefresh(); } }, [
            el("span", { html: ICON.plus }), el("span", { text: "質問を追加" }),
          ]));
        };
        renderQa();
        qaWrap.appendChild(block);
        form.appendChild(qaWrap);
      }

      // --- ロゴ --------------------------------------------------------------
      function buildLogoForm(form) {
        const d = state.draft;
        form.appendChild(fieldText("企業名", "ロゴ画像の説明にも使われます。",
          d.name, (v) => (d.name = v), { placeholder: "例: 株式会社サンプル" }));
        form.appendChild(fieldUpload({
          label: "ロゴ画像", help: "PNG / SVG / JPG が使えます。",
          folder: "logos", shape: "logo", accept: "image/*", storeBasename: true,
          value: { get: () => d.file, set: (v) => (d.file = v) },
          fieldKey: "logo.file",
        }));
      }

      // --- FAQ ---------------------------------------------------------------
      function buildFaqForm(form) {
        const d = state.draft;
        form.appendChild(fieldText("質問", "", d.q, (v) => (d.q = v),
          { placeholder: "例: 料金について教えてください" }));
        form.appendChild(fieldArea("回答", "", d.a, (v) => (d.a = v),
          { rows: 6, placeholder: "回答を入力してください" }));
      }

      // =====================================================================
      // PREVIEW OVERLAY — 編集中ドラフトを LP 忠実に表示
      // =====================================================================
      function openPreview() {
        const sec = SECTIONS[state.sectionId];
        const ov = $("overlay");
        const body = el("div", { class: "ov-body" });
        body.appendChild(el("p", { class: "ov-note", html:
          "ここはプレビューです。実際のサイトへの反映は保存後、数分かかります。" }));
        const frame = el("div", { class: "pv-frame" });
        frame.appendChild(buildPreviewNode(state.sectionId, state.draft));
        body.appendChild(frame);

        const onEsc = (e) => { if (e.key === 'Escape') { ov.innerHTML = ''; document.removeEventListener('keydown', onEsc); } };
        const overlay = el("div", { class: "ov", role: "dialog", "aria-modal": "true", "aria-label": sec.name + " プレビュー" }, [
          el("div", { class: "ov-bar" }, [
            el("span", { class: "ov-title", text: sec.name + " プレビュー" }),
            el("span", { class: "ov-badge", text: "表示イメージ" }),
            el("button", { class: "ov-close", type: "button", "aria-label": "閉じる",
              html: ICON.x, onClick: () => { ov.innerHTML = ""; document.removeEventListener('keydown', onEsc); } }),
          ]),
          body,
        ]);
        ov.innerHTML = "";
        ov.appendChild(overlay);
        document.addEventListener('keydown', onEsc);
      }

      function buildPreviewNode(sid, d) {
        if (sid === "banner") {
          // M3: アップロード直後はlocalUrlsを優先
          const src = resolveImgUrl("banner.image", d.image, false);
          const box = el("div", { class: "pv-banner" + (d.enabled ? "" : " is-off") });
          if (!d.enabled) box.appendChild(el("span", { class: "pv-off-tag", text: "非表示中" }));
          box.appendChild(src ? imgFallback(src, d.alt || "") : el("div", { style: "padding:40px;text-align:center;color:#8a93a6", text: "画像が未設定です" }));
          return box;
        }
        if (sid === "interviews") {
          const card = el("div", { class: "pv-iv" });
          if (d.sample) card.appendChild(el("span", { class: "pv-iv-chip", text: "SAMPLE" }));
          const av = resolveImgUrl("iv.avatar", d.avatar, false);
          card.appendChild(el("div", { class: "pv-iv-head" }, [
            el("div", { class: "pv-iv-av" }, av ? [imgFallback(av, "")] : []),
            el("div", {}, [
              el("p", { class: "pv-iv-org", text: d.org || "（組織名なし）" }),
              el("p", { class: "pv-iv-scale", text: [d.scale, d.role].filter(Boolean).join("｜") }),
            ]),
          ]));
          const dl = el("dl", { class: "pv-iv-qa" });
          (Array.isArray(d.qa) ? d.qa : []).forEach((qa) => {
            dl.appendChild(el("div", {}, [
              el("dt", {}, [el("span", { class: "qmark", text: "Q" }), document.createTextNode(qa.q || "")]),
              el("dd", { text: qa.a || "" }),
            ]));
          });
          card.appendChild(dl);
          return card;
        }
        if (sid === "faqs") {
          return el("div", { class: "pv-faq" }, [
            el("p", { class: "pv-faq-q" }, [el("span", { class: "qn", text: "Q" }), document.createTextNode(d.q || "（質問が空です）")]),
            el("p", { class: "pv-faq-a", text: d.a || "（回答が空です）" }),
          ]);
        }
        if (sid === "docs") {
          return el("div", { class: "pv-doc" }, [
            el("div", { class: "pv-doc-ico", text: "📄" }),
            el("div", {}, [
              el("p", { class: "pv-doc-t", text: d.title || "（無題の資料）" }),
              el("p", { class: "pv-doc-d", text: d.description || "" }),
              el("p", { class: "pv-doc-meta", text:
                (d.date ? d.date + "・" : "") + (d.available ? "公開中" : "準備中") + (d.file ? "・PDFあり" : "・PDF未設定") }),
            ]),
          ]);
        }
        if (sid === "logos") {
          const lu = resolveImgUrl("logo.file", d.file, true);
          return el("div", { class: "pv-logos" }, [
            el("div", { class: "pv-logo" }, lu ? [imgFallback(lu, d.name || "")] : [el("span", { style: "font-size:12px;color:#8a93a6", text: "未設定" })]),
          ]);
        }
        return el("div", {});
      }

      // =====================================================================
      // DESKTOP 3-PANE RENDERING
      // =====================================================================
      function enterDesktop() {
        document.getElementById('appDesktop').classList.remove('hidden');
        document.getElementById('app').classList.add('hidden');
        renderSidebar();
        // pick first section or restore
        if (!state.sectionId) state.sectionId = SECTION_ORDER[0];
        renderDesktopSection();
        document.getElementById('deskLogout').onclick = logout;
      }

      function renderSidebar() {
        const nav = document.getElementById('deskSidebar');
        if (!nav) return;
        nav.innerHTML = '';
        // コンテンツセクションラベル
        const label = el('p', { class: 'side-label', text: 'コンテンツ' });
        nav.appendChild(label);
        SECTION_ORDER.forEach(sid => {
          const sec = SECTIONS[sid];
          const entry = state.store[sec.key];
          let metaTxt = '';
          if (state.loading || !entry) {
            metaTxt = '…';
          } else if (sec.kind === 'object') {
            metaTxt = entry.data?.enabled ? '表示中' : '非表示';
          } else {
            metaTxt = `${Array.isArray(entry.data) ? entry.data.length : 0}件`;
          }
          const tab = el('button', {
            class: 'side-tab' + (state.sectionId === sid ? ' is-active' : ''),
            type: 'button',
            'aria-current': state.sectionId === sid ? 'page' : 'false',
            onClick: () => {
              revokeAllLocalUrls();
              state.sectionId = sid;
              state.draft = null;
              state.draftIndex = null;
              renderSidebar();
              renderDesktopSection();
            }
          }, [
            el('div', { class: 'side-tab-inner' }, [
              el('span', { class: 'side-tab-ico' }, [secIconImg(sec, 20)]),
              el('span', { class: 'side-tab-tx' }, [
                el('span', { class: 'side-tab-name', text: sec.name }),
                el('span', { class: 'side-tab-meta', text: metaTxt }),
              ]),
            ]),
          ]);
          nav.appendChild(tab);
        });
      }

      function renderDesktopSection() {
        if (!isDesktop()) return;
        const sec = SECTIONS[state.sectionId];
        const center = document.getElementById('deskCenter');
        if (!center) return;

        if (state.draft !== null) {
          // Edit form mode
          renderDesktopEdit();
        } else if (sec.kind === 'object') {
          // Banner: go straight to edit
          const entry = state.store[sec.key];
          state.draft = deepClone(entry?.data || defaultDraft(state.sectionId));
          state._draftSnapshot = JSON.stringify(state.draft);
          state.draftIndex = 0;
          renderDesktopEdit();
        } else {
          // Array: list mode
          renderDesktopList();
        }
        renderDesktopPreview();
      }

      function renderDesktopList() {
        const sec = SECTIONS[state.sectionId];
        const entry = state.store[sec.key];
        const items = Array.isArray(entry?.data) ? entry.data : [];
        const center = document.getElementById('deskCenter');

        const head = el('div', { class: 'desk-center-head' }, [
          el('div', { style: 'min-width:0;flex:1 1 auto' }, [
            el('h2', { class: 'desk-center-title', style: 'margin:0' }, [
              el('span', { class: 'desk-title-ico' }, [secIconImg(sec, 22)]),
              el('span', { text: sec.name }),
            ]),
            el('p', { class: 'desk-section-desc', style: 'margin:2px 0 0', text: sec.desc }),
          ]),
          el('button', { class: 'btn-add', type: 'button', onClick: () => {
            revokeAllLocalUrls();
            state.draft = defaultDraft(state.sectionId);
            state._draftSnapshot = JSON.stringify(state.draft);
            state.draftIndex = null;
            renderDesktopEdit();
            renderDesktopPreview();
          }}, [
            el('span', { html: ICON.plus }), el('span', { text: '追加' }),
          ]),
        ]);

        const body = el('div', { class: 'desk-center-body' });
        if (items.length === 0) {
          body.appendChild(el('div', { class: 'empty' }, [
            el('div', { class: 'empty-ico' }, [secIconImg(sec, 48)]),
            el('p', { text: 'まだ登録がありません。' }),
          ]));
        } else {
          const ul = el('div', { class: 'item-list' });
          items.forEach((item, i) => {
            const card = renderItemCard(state.sectionId, item, i, items.length);
            // Override tap handler: desktop opens in center pane
            const tapBtn = card.querySelector('.item-tap');
            if (tapBtn) {
              tapBtn.onclick = () => {
                revokeAllLocalUrls();
                state.draft = deepClone(entry.data[i]);
                state._draftSnapshot = JSON.stringify(state.draft);
                state.draftIndex = i;
                renderDesktopEdit();
                renderDesktopPreview();
              };
            }
            // Override edit icon button too
            const editBtns = card.querySelectorAll('.ic-btn:not(.is-danger)');
            // last non-danger ic-btn is the edit button (after the two arrows)
            const editBtn = editBtns[editBtns.length - 1];
            if (editBtn) {
              editBtn.onclick = () => {
                revokeAllLocalUrls();
                state.draft = deepClone(entry.data[i]);
                state._draftSnapshot = JSON.stringify(state.draft);
                state.draftIndex = i;
                renderDesktopEdit();
                renderDesktopPreview();
              };
            }
            ul.appendChild(card);
          });
          body.appendChild(ul);
        }

        center.innerHTML = '';
        center.appendChild(head);
        center.appendChild(body);
      }

      function renderDesktopEdit() {
        const sec = SECTIONS[state.sectionId];
        const center = document.getElementById('deskCenter');

        const isNew = state.draftIndex === null && sec.kind === 'array';
        const titleTxt = isNew ? '新規追加' : '編集';

        const titleContent = [];
        if (sec.kind === 'array') {
          titleContent.push(el('button', { class: 'desk-back-btn', type: 'button', onClick: () => {
            revokeAllLocalUrls();
            state.draft = null;
            state.draftIndex = null;
            renderDesktopSection();
          }}, [el('span', { html: ICON.back }), el('span', { text: '一覧へ' })]));
        }
        titleContent.push(el('span', { text: titleTxt }));

        const saveBtn = el('button', {
          class: 'desk-save-btn', type: 'button',
          text: state.saving ? '保存中…' : '保存',
          onClick: () => saveDraft(),
        });
        if (state.saving || !isDirty()) saveBtn.setAttribute('disabled', '');

        const head = el('div', { class: 'desk-center-head' }, [
          el('h2', { class: 'desk-center-title' }, titleContent),
          saveBtn,
        ]);

        const body = el('div', { class: 'desk-center-body' });
        const form = el('form', { class: 'form', onSubmit: (e) => { e.preventDefault(); saveDraft(); } });
        if (state.sectionId === 'banner') buildBannerForm(form);
        else if (state.sectionId === 'docs') buildDocForm(form);
        else if (state.sectionId === 'interviews') buildInterviewForm(form);
        else if (state.sectionId === 'logos') buildLogoForm(form);
        else if (state.sectionId === 'faqs') buildFaqForm(form);
        body.appendChild(form);

        center.innerHTML = '';
        center.appendChild(head);
        center.appendChild(body);
      }

      function renderDesktopPreview() {
        const pv = document.getElementById('deskPreview');
        if (!pv) return;

        const head = el('div', { class: 'desk-pv-head' }, [
          el('p', { class: 'desk-pv-label', text: 'PREVIEW' }),
          el('p', { class: 'desk-pv-note', text: '保存後、数分で本番に反映されます。' }),
        ]);

        const body = el('div', { class: 'desk-pv-body' });
        if (state.draft) {
          body.appendChild(buildPreviewNode(state.sectionId, state.draft));
        } else {
          const sec2 = SECTIONS[state.sectionId];
          body.appendChild(el('div', { class: 'desk-pv-empty' }, [
            sec2 ? el('div', { style: 'margin-bottom:10px;display:flex;justify-content:center' }, [secIconImg(sec2, 40)]) : null,
            el('p', { style: 'margin:0', text: '編集する項目を選ぶとプレビューが表示されます' }),
          ]));
        }

        pv.innerHTML = '';
        pv.appendChild(head);
        pv.appendChild(body);
      }

      // =====================================================================
      // NAVIGATION / ACTIONS
      // =====================================================================
      function go(v) {
        // M3: edit を離れるときに保持していたObjectURLを破棄
        if (state.view === "edit" && v !== "edit") revokeAllLocalUrls();
        state.view = v;
        renderBar();
        if (v === "home") renderHome();
        else if (v === "list") renderList();
        else if (v === "edit") renderEdit();
        window.scrollTo({ top: 0, behavior: "instant" in window ? "instant" : "auto" });
      }

      function openSection(sid) {
        state.sectionId = sid;
        const sec = SECTIONS[sid];
        if (sec.kind === "object") {
          // バナー: 直接編集
          const entry = state.store[sec.key];
          state.draft = deepClone(entry?.data || defaultDraft(sid));
          state._draftSnapshot = JSON.stringify(state.draft);
          state.draftIndex = 0; // 単体は固定
          go("edit");
        } else {
          go("list");
        }
      }

      function openEditor(index) {
        const sec = SECTIONS[state.sectionId];
        const entry = state.store[sec.key];
        if (index === null) {
          state.draft = defaultDraft(state.sectionId);
          state._draftSnapshot = JSON.stringify(state.draft);
          state.draftIndex = null;
        } else {
          state.draft = deepClone(entry.data[index]);
          state._draftSnapshot = JSON.stringify(state.draft);
          state.draftIndex = index;
        }
        go("edit");
      }

      function defaultDraft(sid) {
        switch (sid) {
          case "banner": return { enabled: true, image: "", alt: "", link: "/docs/", newTab: false };
          case "docs": return { title: "", description: "", file: "", date: "", available: false };
          case "interviews": return { sample: true, org: "", scale: "", role: "導入ご担当者", avatar: "", qa: [{ q: "", a: "" }] };
          case "logos": return { file: "", name: "" };
          case "faqs": return { q: "", a: "" };
          default: return {};
        }
      }
      const deepClone = (o) => JSON.parse(JSON.stringify(o));
      const isDirty = () => state.draft !== null && JSON.stringify(state.draft) !== state._draftSnapshot;

      async function onLeaveEdit() {
        if (isDirty()) {
          const ok = await confirmDialog({
            title: "編集をやめますか？",
            message: "保存していない変更は反映されません。",
            okLabel: "編集をやめる", danger: true,
          });
          if (!ok) return;
        }
        const sec = SECTIONS[state.sectionId];
        go(sec.kind === "object" ? "home" : "list");
      }

      async function saveDraft() {
        if (state.saving) return;
        const sec = SECTIONS[state.sectionId];
        let entry = state.store[sec.key];

        // M1: sha欠落ガード。loadAll失敗でsha=nullのまま保存すると422になるため再取得
        if (!entry?.sha) {
          try {
            const fresh = await apiGet(sec.key);
            state.store[sec.key] = { data: fresh.data, sha: fresh.sha };
            entry = state.store[sec.key];
          } catch (e2) {
            toast("データの読み込みに失敗しました。ページを再読み込みしてください。", { error: true, icon: false });
            return;
          }
        }

        let nextData;
        if (sec.kind === "object") {
          nextData = state.draft;
        } else {
          const arr = Array.isArray(entry?.data) ? deepClone(entry.data) : [];
          if (state.draftIndex === null) arr.push(state.draft);
          else arr[state.draftIndex] = state.draft;
          nextData = arr;
        }

        state.saving = true;
        renderBar();
        try {
          const res = await apiSave(sec.key, nextData, entry.sha, `Update ${sec.key} via CMS`);
          state.store[sec.key] = { data: res.data, sha: res.sha };
          state.saving = false;
          state._draftSnapshot = null;  // dirty解除
          toast(
            `保存しました。数分で本番に反映されます。 <a href="${SITE_URL}" target="_blank" rel="noopener noreferrer" style="color:#9ec2ff;font-weight:700">本番を確認 ↗</a>`,
            { icon: true, duration: 8000 }
          );
          if (isDesktop()) {
            revokeAllLocalUrls();
            renderSidebar();
            state.draft = null;
            state.draftIndex = null;
            if (sec.kind === "array") renderDesktopList();
            else renderDesktopSection();
            renderDesktopPreview();
          } else {
            go(sec.kind === "object" ? "home" : "list");
          }
        } catch (err) {
          state.saving = false;
          renderBar();
          // M1: 古いshaへ戻さない。代わりに最新を再取得してストアを更新
          try {
            const fresh = await apiGet(sec.key);
            state.store[sec.key] = { data: fresh.data, sha: fresh.sha };
          } catch (_) { /* 再取得失敗は無視。次回保存時にガードが再試行する */ }
          toast(esc(err.message) + " — 最新の状態に更新しました。もう一度保存してください。", { error: true, icon: false, duration: 6000 });
        }
      }

      async function deleteItem(index) {
        const sec = SECTIONS[state.sectionId];
        const ok = await confirmDialog({
          title: "削除しますか？", message: "この項目を削除します。元に戻せません。",
          okLabel: "削除する", danger: true,
        });
        if (!ok) return;
        const arr = deepClone(state.store[sec.key].data);
        arr.splice(index, 1);
        await persistArray(sec, arr, "削除しました。");
      }

      async function moveItem(index, dir) {
        const sec = SECTIONS[state.sectionId];
        const arr = deepClone(state.store[sec.key].data);
        const to = index + dir;
        if (to < 0 || to >= arr.length) return;
        [arr[index], arr[to]] = [arr[to], arr[index]];
        await persistArray(sec, arr, "並び替えました。");
      }

      async function persistArray(sec, arr, okMsg) {
        const entry = state.store[sec.key];
        // 楽観更新でUIを即反映
        state.store[sec.key] = { data: arr, sha: entry.sha };
        renderList();
        if (isDesktop()) { renderSidebar(); renderDesktopList(); }
        try {
          const res = await apiSave(sec.key, arr, entry.sha, `Update ${sec.key} via CMS`);
          state.store[sec.key] = { data: res.data, sha: res.sha };
          renderList();
          if (isDesktop()) { renderSidebar(); renderDesktopList(); }
          toast(okMsg);
        } catch (err) {
          // M1: 古いshaに戻さない。最新を再取得してストアを更新し再描画
          try {
            const fresh = await apiGet(sec.key);
            state.store[sec.key] = { data: fresh.data, sha: fresh.sha };
          } catch (_) { /* 再取得失敗は無視 */ }
          renderList();
          if (isDesktop()) { renderSidebar(); renderDesktopList(); }
          toast(esc(err.message) + " — 最新の状態に更新しました。もう一度お試しください。", { error: true, icon: false, duration: 6000 });
        }
      }

      // =====================================================================
      // BOOT / AUTH
      // =====================================================================
      async function loadAll() {
        state.loading = true;
        renderHome();
        const keys = SECTION_ORDER.map((sid) => SECTIONS[sid].key);
        await Promise.all(keys.map(async (key) => {
          try {
            const res = await apiGet(key);
            state.store[key] = { data: res.data, sha: res.sha };
          } catch (err) {
            state.store[key] = { data: key === "banner" ? {} : [], sha: null, error: err.message };
          }
          if (state.view === "home") renderHome();
          if (isDesktop() && state.view !== 'edit') renderSidebar();
          if (!isDesktop()) renderHamNav();
        }));
        state.loading = false;
        if (state.view === "home") renderHome();
        if (!isDesktop()) renderHamNav();
        if (isDesktop()) {
          renderSidebar();
          // 起動直後: object型(バナー)は load前に default で seed されているため、
          // 実データで draft を作り直してから再描画する。
          const sec = SECTIONS[state.sectionId];
          if (sec && sec.kind === "object" && state.draftIndex === 0) {
            const entry = state.store[sec.key];
            state.draft = deepClone(entry?.data || defaultDraft(state.sectionId));
            state._draftSnapshot = JSON.stringify(state.draft);
          }
          renderDesktopSection();
        }
      }

      function enterApp() {
        $("login").classList.add("hidden");
        if (isDesktop()) {
          enterDesktop();
        } else {
          $("app").classList.remove("hidden");
          go("home");
        }
        loadAll();
      }
      function logout() {
        const deskApp = document.getElementById('appDesktop');
        if (deskApp) deskApp.classList.add('hidden');
        closeDrawer(); // ドロワーが開いていれば閉じる
        revokeAllLocalUrls();
        sessionStorage.removeItem(PW_STORE_KEY);
        state.password = "";
        state.store = {};
        state.draft = null;
        state.draftIndex = null;
        $("app").classList.add("hidden");
        $("login").classList.remove("hidden");
        $("loginPw").value = "";
      }

      // login form
      $("loginForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const pw = $("loginPw").value.trim();
        const err = $("loginErr");
        const btn = $("loginBtn");
        if (!pw) { err.textContent = "パスワードを入力してください。"; err.classList.remove("hidden"); return; }
        err.classList.add("hidden");
        btn.setAttribute("disabled", "");
        btn.textContent = "確認中…";
        state.password = pw;
        try {
          await apiGet("banner"); // 認証チェック
          sessionStorage.setItem(PW_STORE_KEY, pw);
          enterApp();
        } catch (e2) {
          err.textContent = e2.message || "ログインに失敗しました。";
          err.classList.remove("hidden");
          state.password = "";
        } finally {
          btn.removeAttribute("disabled");
          btn.textContent = "ログイン";
        }
      });

      // resume session
      (function init() {
        const saved = sessionStorage.getItem(PW_STORE_KEY);
        if (saved) { state.password = saved; enterApp(); }
      })();

      // Resize: switch layout when crossing 1024px breakpoint
      let _wasDesktop = isDesktop();
      window.addEventListener('resize', () => {
        const nowDesktop = isDesktop();
        if (nowDesktop === _wasDesktop) return;
        _wasDesktop = nowDesktop;
        if (!state.password) return; // not logged in
        revokeAllLocalUrls();
        if (nowDesktop) {
          $('app').classList.add('hidden');
          if (!state.sectionId) state.sectionId = SECTION_ORDER[0];
          state.draft = null;
          state.draftIndex = null;
          enterDesktop();
        } else {
          document.getElementById('appDesktop').classList.add('hidden');
          $('app').classList.remove('hidden');
          state.draft = null;
          state.draftIndex = null;
          go('home');
        }
      });

    </script>
  </body>
</html>
