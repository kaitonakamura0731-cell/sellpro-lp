      function renderItemCard(sid, item, i, total) {
        let thumb, title, sub, tags = [];

        if (sid === "docs") {
          thumb = el("span", { class: "item-thumb", text: "📄" });
          title = item.title || "（無題の資料）";
          sub = item.date || "日付未設定";
          tags.push(tag(item.available ? "公開中" : "非公開", item.available ? "" : "tag-off"));
          if (item.file) tags.push(tag("PDFあり"));
        } else if (sid === "interviews") {
          const av = assetUrl(item.avatar);
          thumb = el("span", { class: "item-thumb" }, av
            ? [imgFallback(av, "")] : [document.createTextNode("💬")]);
          title = item.org || "（組織名なし）";
          sub = [item.scale, item.role].filter(Boolean).join("｜") || "詳細未設定";
          if (item.sample) tags.push(tag("サンプル", "tag-sample"));
          tags.push(tag(`Q&A ${Array.isArray(item.qa) ? item.qa.length : 0}件`));
        } else if (sid === "logos") {
          const lu = logoUrl(item.file);
          thumb = el("span", { class: "item-thumb is-logo" }, lu
            ? [imgFallback(lu, "")] : [document.createTextNode("🏢")]);
          title = item.name || "（企業名なし）";
          sub = item.file || "画像未設定";
        } else { // faqs
          thumb = el("span", { class: "item-thumb", text: "❓" });
          title = item.q || "（質問が空です）";
          sub = item.a ? String(item.a).slice(0, 40) : "回答未設定";
        }

        const card = el("article", { class: "item-card" });
        card.appendChild(thumb);

        const main = el("button", { class: "item-tap", type: "button", onClick: () => openEditor(i) }, [
          el("p", { class: "item-title", text: title }),
          el("p", { class: "item-sub", text: sub }),
          tags.length ? el("div", { class: "item-tags" }, tags) : null,
        ]);
        const mainWrap = el("div", { class: "item-main" }, [main]);
        card.appendChild(mainWrap);

        // 並び替え矢印
        const arrows = el("div", { class: "item-arrows" }, [
          iconBtn(ICON.arrowUp, "上へ", () => moveItem(i, -1), i === 0),
          iconBtn(ICON.arrowDown, "下へ", () => moveItem(i, 1), i === total - 1),
        ]);
        card.appendChild(arrows);

        // 編集 / 削除
        const acts = el("div", { class: "item-actions" }, [
          iconBtn(ICON.edit, "編集", () => openEditor(i)),
          iconBtn(ICON.trash, "削除", () => deleteItem(i), false, true),
        ]);
        card.appendChild(acts);
        return card;
      }

      const tag = (txt, cls = "") => el("span", { class: "tag " + cls, text: txt });
      const iconBtn = (svg, label, fn, disabled = false, danger = false) => {
        const b = el("button", {
          class: "ic-btn" + (danger ? " is-danger" : ""), type: "button",
          "aria-label": label, title: label, html: svg, onClick: fn,
        });
        if (disabled) b.setAttribute("disabled", "");
        return b;
      };
      const imgFallback = (src, alt) => {
        const img = el("img", { src, alt });
        img.addEventListener("error", () => {
          img.replaceWith(el("span", { style: "font-size:18px", text: "🖼" }));
        });
        return img;
      };

      // =====================================================================
      // FORMS — 編集フォーム生成（種別ごと）
      // =====================================================================
      function renderEdit() {
        const sec = SECTIONS[state.sectionId];
        const root = view();
        root.innerHTML = "";
        const v = el("div", { class: "view" });
        const form = el("form", { class: "form", onSubmit: (e) => { e.preventDefault(); saveDraft(); } });

        if (state.sectionId === "banner") buildBannerForm(form);
        else if (state.sectionId === "docs") buildDocForm(form);
        else if (state.sectionId === "interviews") buildInterviewForm(form);
        else if (state.sectionId === "logos") buildLogoForm(form);
        else if (state.sectionId === "faqs") buildFaqForm(form);

        // フッタ: 保存 + プレビュー
        form.appendChild(el("div", { class: "form-foot" }, [
          el("button", {
            class: "btn-primary-full", type: "button",
            text: state.saving ? "保存中…" : "保存する",
            onClick: () => saveDraft(),
          }),
          el("button", { class: "btn-preview", type: "button", onClick: () => openPreview() }, [
            el("span", { html: ICON.eye }), el("span", { text: "プレビューを見る" }),
          ]),
        ]));
        v.appendChild(form);
        root.appendChild(v);
      }

      // --- 汎用フィールド部品 -------------------------------------------------
      let _fieldIdCtr = 0;
      const fieldText = (label, help, value, onInput, opts = {}) => {
        const fid = 'f' + (++_fieldIdCtr);
        const inp = el("input", {
          id: fid, class: "input", type: opts.type || "text", value: value ?? "",
          placeholder: opts.placeholder || "", inputmode: opts.inputmode || null,
          onInput: (e) => { onInput(e.target.value); schedulePreviewRefresh(); },
        });
        return el("div", { class: "field" }, [
          el("label", { class: "field-label", for: fid, text: label }),
          help ? el("p", { class: "field-help", text: help }) : null,
          inp,
        ]);
      };
      const fieldArea = (label, help, value, onInput, opts = {}) => {
        const fid = 'f' + (++_fieldIdCtr);
        const ta = el("textarea", {
          id: fid, class: "textarea", placeholder: opts.placeholder || "",
          rows: opts.rows || 4, onInput: (e) => { onInput(e.target.value); schedulePreviewRefresh(); },
        });
        ta.value = value ?? "";
        return el("div", { class: "field" }, [
          el("label", { class: "field-label", for: fid, text: label }),
          help ? el("p", { class: "field-help", text: help }) : null,
          ta,
        ]);
      };
      const fieldToggle = (label, help, checked, onToggle) => {
        const sw = el("button", {
          class: "switch", type: "button", role: "switch",
          "aria-checked": checked ? "true" : "false", "aria-label": label,
        });
        sw.addEventListener("click", () => {
          const next = sw.getAttribute("aria-checked") !== "true";
          sw.setAttribute("aria-checked", next ? "true" : "false");
          onToggle(next);
          schedulePreviewRefresh();
        });
        return el("div", { class: "field" }, [
          el("div", { class: "toggle-row" }, [
            el("div", { class: "toggle-tx" }, [
              el("label", { class: "field-label", text: label }),
              help ? el("p", { class: "field-help", style: "margin-bottom:0", text: help }) : null,
            ]),
            sw,
          ]),
        ]);
      };

      // --- アップロード部品 ---------------------------------------------------
      // shape: "banner" | "logo" | "avatar" | "pdf"
      // storeBasename=true なら格納値を basename のみにする（ロゴ用）
      // fieldKey: state.localUrls のキー（フォーム内で一意）
      function fieldUpload({ label, help, folder, shape, accept, value, onChange, storeBasename = false, fieldKey }) {
        const field = el("div", { class: "field" });
        field.appendChild(el("label", { class: "field-label", text: label }));
        if (help) field.appendChild(el("p", { class: "field-help", text: help }));

        const up = el("div", { class: "uploader" });
        const previewBox = el("div", { class: "up-preview is-" + shape });
        const status = el("p", { class: "up-status hidden", role: "status", "aria-live": "polite" });

        // M3: ローカルObjectURL優先、なければストア値を解決
        const currentPreviewSrc = () => {
          if (state.localUrls[fieldKey]) return state.localUrls[fieldKey];
          return shape === "logo" ? logoUrl(value.get()) : assetUrl(value.get());
        };

        const drawPreview = (overrideUrl) => {
          previewBox.innerHTML = "";
          const src = overrideUrl || currentPreviewSrc();
          if (shape === "pdf") {
            const has = !!value.get();
            previewBox.appendChild(el("span", { class: "up-ph-ico", text: has ? "📕" : "📄" }));
            previewBox.appendChild(el("span", { text: has ? (value.get()) : "PDF 未設定" }));
          } else if (src) {
            previewBox.appendChild(imgFallback(src, ""));
          } else {
            previewBox.appendChild(el("span", { text: "画像が未設定です" }));
          }
        };
        drawPreview();

        const input = el("input", {
          type: "file", accept, class: "hidden",
          "aria-label": label + "を選択",
        });
        input.addEventListener("change", async () => {
          const file = input.files && input.files[0];
          input.value = "";
          if (!file) return;

          // 即時ローカルプレビュー（M3: ObjectURLは成功後も保持）
          const objUrl = shape === "pdf" ? null : URL.createObjectURL(file);
          if (objUrl) {
            // 以前のObjectURLがあれば先に破棄してから新URLを登録
            if (state.localUrls[fieldKey]) {
              try { URL.revokeObjectURL(state.localUrls[fieldKey]); } catch (_) {}
            }
            state.localUrls[fieldKey] = objUrl;
            drawPreview(objUrl);
          } else {
            previewBox.innerHTML = "";
            previewBox.appendChild(el("span", { class: "up-ph-ico", text: "📕" }));
            previewBox.appendChild(el("span", { text: file.name }));
          }

          status.className = "up-status is-busy";
          status.innerHTML = "";
          status.appendChild(el("span", { class: "spin" }));
          status.appendChild(el("span", { text: "アップロード中…" }));

          try {
            const res = await uploadFile(folder, file);
            // 格納値の決定（規約）
            let stored = res.path;
            if (storeBasename) stored = res.path.split("/").pop();
            value.set(stored);
            onChange && onChange(stored);
            schedulePreviewRefresh();
            // M3: revokeしない。ObjectURLはstate.localUrlsに保持し、フォーム離脱時に破棄。
            // サムネを再描画（localUrls[fieldKey]が優先される）
            drawPreview();
            status.className = "up-status is-ok";
            status.innerHTML = "";
            status.appendChild(el("span", { html: ICON.check }));
            status.appendChild(el("span", { text: "アップロード完了。本番反映は数分後（プレビューは選択した画像を表示中）" }));
          } catch (err) {
            // 失敗時はローカルObjectURLを破棄してストア値に戻す
            if (objUrl && state.localUrls[fieldKey] === objUrl) {
              try { URL.revokeObjectURL(objUrl); } catch (_) {}
              delete state.localUrls[fieldKey];
            }
            status.className = "up-status is-err";
            status.textContent = "失敗: " + err.message;
            drawPreview();
          }
        });

        const btnLabel = shape === "pdf" ? "PDFを選ぶ" : "画像をアップロード";
        up.appendChild(previewBox);
        up.appendChild(el("div", { class: "up-row" }, [
          el("button", { class: "btn-up", type: "button", onClick: () => input.click() }, [
            el("span", { html: ICON.up }), el("span", { text: btnLabel }),
          ]),
          input,
        ]));
        up.appendChild(status);

        // 上級者向け: 手入力（折りたたみ）
        const adv = el("details", { class: "adv" });
        adv.appendChild(el("summary", { text: "ファイル名を直接入力（上級者向け）" }));
        const manual = el("input", {
          class: "input", type: "text", value: value.get() || "",
          placeholder: storeBasename ? "例: company.png" : "例: " + folder + "/file.webp",
        });
        manual.addEventListener("input", (e) => { value.set(e.target.value); onChange && onChange(e.target.value); drawPreview(); schedulePreviewRefresh(); });
        adv.appendChild(manual);
        up.appendChild(adv);

        field.appendChild(up);
        return field;
      }

      // --- バナー ------------------------------------------------------------
      function buildBannerForm(form) {
        const d = state.draft;
        form.appendChild(fieldToggle(
          "バナーを表示する", "オフにすると、サイト下部の案内バナーが消えます。",
