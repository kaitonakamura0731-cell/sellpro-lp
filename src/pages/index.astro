---
// SellPro LP — exa-1（exaBase寄せ・忠実再現派）
// コンテンツは bold版（site/src/pages/index.astro）と同一。デザインのみ exaBase 調に再構成。
// 一次情報: SellPro説明資料 2026.05.19。コピーは全て資料の事実に基づく
// ルート配置。アセット参照は logos/... product/... の相対パス
import "../styles/exa.css";
import CtaBand from "../components/CtaBandExa.astro";
import FloatingBanner from "../components/FloatingBanner.astro";
import FeatureMock from "../components/FeatureMock.astro";
// 導入インタビューはコンテンツファイル方式。編集は src/data/interviews.json で行う。
// 各エントリの sample:true はサンプル注記/SAMPLEチップの表示制御。実物に差し替えたら false にする。
import interviews from "../data/interviews.json";
// 導入企業ロゴ・FAQはコンテンツファイル方式。編集は src/data/logos.json / faqs.json で行う。
import logos from "../data/logos.json";
import faqs from "../data/faqs.json";

const meta = {
  title: "SellPro（セルプロ）| スライド・議事録作成を自動化するAIエージェント - One StepS",
  description:
    "スライド資料と議事録の作成をAIが代行。トンマナ学習で自社フォーマットのまま生成。資料作成工数を約30〜70%削減（※当社調べ）するAIエージェント「SellPro」。",
};

// 導入企業ロゴウォール 17社（harvest-map.json の logos セクション準拠）
// - ADIロゴは帝国不動産（teikoku.png）と同一企業のため重複掲載しない
// → src/data/logos.json に外出し済み（上部の import logos を参照）

// 主な機能（資料 page-04 の記載を書き起こし）
const featureGroups = [
  {
    label: "スライドAI",
    en: "SLIDE AI",
    items: [
      {
        no: "01",
        viz: "prompt",
        title: "指示だけで、資料が完成",
        body: "内容を伝えるだけで生成。手元のドキュメントのスライド化も可能です。",
      },
      {
        no: "02",
        viz: "layout",
        title: "構成・デザインの自動最適化",
        body: "AIが構成を組み立て、デザインも整えます。",
      },
      {
        no: "03",
        viz: "tonmana",
        title: "トンマナ・テンプレート設定",
        body: "設定したトンマナは生成スライドへ自動反映されます。",
      },
    ],
  },
  {
    label: "議事録AI",
    en: "MINUTES AI",
    items: [
      {
        no: "04",
        viz: "transcribe",
        title: "文字起こしから議事録まで3〜5分程度",
        body: "自動文字起こしから議事録作成まで一気通貫。",
      },
      {
        no: "05",
        viz: "diarize",
        title: "高度な話者識別と整理",
        body: "「誰が・何を言ったか」を正確に識別・整理します。",
      },
      {
        no: "06",
        viz: "summary",
        title: "テンプレート議事録・要約",
        body: "テンプレートに沿った議事録の作成・要約ができます。",
      },
    ],
  },
];

// 選ばれる理由（課題織り込み型・資料 page-04/06/12/13 の事実から構成）
const reasons = [
  {
    no: "01",
    viz: "copypaste",
    title: "「AIで作って、自社フォーマットにコピペし直す」を、ゼロに。",
    body: "普段のpptxを上げるだけで、レイアウト・カラー・フォントをAIが自動学習。最初から自社トンマナで直接生成するので、体裁直しがいりません。",
    fact: "pptxのアップロードでレイアウト・ブランドカラー・フォントルールを学習（説明資料記載）。",
  },
  {
    no: "02",
    viz: "speaker",
    title: "「誰が・何を言ったか」まで残る議事録。",
    body: "録音から文字起こし→議事録まで3〜5分程度※。話者を識別し、決定事項・ToDoの抽出まで続けられます。",
    fact: "当社調べ。話者識別を含むテンプレート要約は5〜10分程度。",
  },
  {
    no: "03",
    viz: "noimage",
    title: "画像生成を、あえて載せない。",
    body: "Web画像の参照もAI画像生成も搭載しない設計。著作権の観点から、企業が安心して使える範囲に機能を絞っています。",
    fact: "「使ってよいか判断に迷う素材」を最初から生まない構造です。",
  },
  {
    no: "04",
    viz: "standard",
    title: "属人化した資料作成を、再現できるプロセスに。",
    body: "不動産・建設業界（約750名）の事例では、営業ごとに品質が異なっていた説明資料づくりを標準化しました。",
    fact: "導入時はトンマナ設定から伴走します。",
  },
];

// 活用シーン8項目（資料 page-05 の書き起こし）
const scenesSlide = [
  "営業提案資料のたたき台作成",
  "社内説明資料・企画資料の作成",
  "マニュアル・ナレッジ資料の整備",
  "既存資料をもとにしたアップデート",
];
const scenesMinutes = [
  "商談・会議の録音から自動で議事録を作成",
  "話者ごとに「誰が何を言ったか」を整理",
  "決定事項・ToDoを自動で抽出",
  "議事録をもとに次回提案資料を作成",
];

// 用途別生成3種（資料 page-07/08/09）
const usecaseTypes = [
  {
    no: "A",
    title: "リサーチ・分析レポート",
    body: "市場調査／競合分析／社内報告資料",
    img: "product/usecase-report.png",
    alt: "SellProで生成したリサーチ・分析レポートの例（日本のIT・スタートアップ産業史の表紙スライド）",
  },
  {
    no: "B",
    title: "提案・説明スライド",
    body: "営業提案／社内共有／サービス説明",
    img: "product/usecase-proposal.png",
    alt: "SellProで生成した提案・説明スライドの例（サービス説明資料）",
  },
  {
    no: "C",
    title: "販促・チラシ風資料",
    body: "サービス紹介チラシ／1枚営業資料",
    img: "product/usecase-flyer.png",
    alt: "SellProで生成した販促・チラシ風資料の例（1枚もののサービス紹介資料）",
  },
];

// インタビューのサンプル注記/SAMPLEチップは、sample:true のエントリが1件以上あるときだけ表示する。
// 全エントリを実物（sample:false）に差し替えると、帯とチップは自動で消える。
const hasSampleInterview = interviews.some((iv) => iv.sample === true);

// FAQ（資料 Q&Aページの書き起こし。JSON-LD FAQPage と同一テキスト）
// → src/data/faqs.json に外出し済み（上部の import faqs を参照）
// 料金・トライアル・導入期間は資料に正式情報がないため、実質同文の3問を1問に統合した非断定回答
//（料金の桁感・初期費用有無の開示可否は要確認 → 田山さんへ照会。正式情報の受領後に個別回答へ再分割して差し替える）。

const ldSoftware = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "SellPro",
  alternateName: "セルプロ",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: meta.description,
  publisher: {
    "@type": "Organization",
    name: "株式会社One StepS",
    url: "https://onesteps.co.jp/",
    address: {
      "@type": "PostalAddress",
      addressLocality: "東京都港区",
      streetAddress: "南青山3-8-40 青山センタービル2F-20",
    },
  },
};

const ldFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <!-- OGP: og:image は本番ドメイン確定後に絶対URLへ差し替える -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:image" content="product/og.png" />
    <meta property="og:site_name" content="SellPro（セルプロ）" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="logos/sellpro.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(ldSoftware)} is:inline></script>
    <script type="application/ld+json" set:html={JSON.stringify(ldFaq)} is:inline></script>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="#top" aria-label="SellPro トップへ">
          <img src="logos/sellpro.svg" alt="SellPro（セルプロ）ロゴ" width="489" height="140" />
        </a>
        <!-- CASE.md「アンカーナビ少なめ」準拠: 常時表示は3本+CTAに絞り、全アンカーはメニュー内に収容 -->
        <nav class="header-nav" aria-label="ページ内ナビゲーション">
          <a href="#features">機能</a>
          <a href="#reasons">選ばれる理由</a>
          <a href="#faq">FAQ</a>
          <a href="/docs/">資料</a>
          <a class="btn btn-vivid" href="/contact/">お問い合わせ</a>
        </nav>
        <!-- 軽量ハンバーガー（details/summary。JSなしでも開閉可能） -->
        <details class="header-menu">
          <summary aria-label="メニュー">
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
              <path d="M3 6h18M3 12h18M3 18h18" stroke="#16335f" stroke-width="2.2" stroke-linecap="round"></path>
            </svg>
          </summary>
          <nav class="hm-panel" aria-label="セクション一覧">
            <a href="#reasons">選ばれる理由</a>
            <a href="#features">機能</a>
            <a href="#usecases">用途別生成</a>
            <a href="#interview">インタビュー</a>
            <a href="#faq">FAQ</a>
            <a href="/docs/">資料</a>
            <a href="/contact/">お問い合わせ</a>
          </nav>
        </details>
      </div>
    </header>

    <main id="top">
      <!-- exaBase文法: ヒーロー + 数値バッジ を1枚の青帯に載せる -->
      <div class="hero-band">
        <!-- 2026-06-11 田山さんFB「TOPは元（初回納品版）が良かった」: 生成背景画像を撤去し、初回納品のCSSグラデーション帯に復元 -->
        <!-- 1. ヒーロー -->
        <section class="hero">
          <!-- SP配置: 見出し→製品画像→訴求の縦流れ。PCは左右2カラムのまま、製品素材を青背景へ直接なじませる。 -->
          <div class="container hero-grid">
            <div class="hero-head">
              <h1>
                <span class="h1-main">スライドも、<br />議事録も、<br /><em>AIが代行。</em></span>
                <span class="h1-sub">
                  スライド・議事録AIエージェント <strong>「SellPro（セルプロ）」</strong> by&nbsp;One&nbsp;StepS
                </span>
              </h1>
            </div>
            <div class="hero-visual">
              <!-- 「SellPro ダッシュボード」タグは田山さんFBで削除（2026-06-11） -->
              <div class="frame">
                <img
                  src="product/hero-minutes-mosaic.webp"
                  alt="SellProの音声記録と議事録AIの画面イメージ"
                  width="1280"
                  height="493"
                  loading="eager"
                />
              </div>
            </div>
            <div class="hero-body">
              <p class="hero-lead">
                資料作成の工数を<span class="pct">約30〜70%</span><span style="white-space: nowrap">削減<sup>※</sup>。</span>
              </p>
              <p class="hero-note">※ 当社調べ。削減効果は資料の種類・内容により異なります。</p>
              <div class="hero-cta">
                <a class="btn btn-vivid" href="/contact/">導入の相談をする</a>
                <a class="ghost" href="/contact/?type=資料請求">資料請求</a>
              </div>
            </div>
          </div>
        </section>

        <!-- 2. 数値バッジ帯（エンブレム風） -->
        <section class="stats" aria-labelledby="stats-h">
          <div class="container">
            <!-- 金月桂樹エンブレムは撤去（2026-06-10 レビュー反映）。金色はSAMPLEチップ等の警告系のみに限定 -->
            <h2 class="stats-label" id="stats-h">導入効果</h2>
            <ul class="stats-grid">
              <li class="stat">
                <div class="stat-label">資料作成工数を削減</div>
                <div class="stat-num">約30<span class="unit">〜</span>70<span class="unit">%</span><sup>※1</sup></div>
                <div class="stat-mini">提案書・社内資料など、種類を問わず効果を発揮</div>
              </li>
              <li class="stat stat-detail">
                <div class="stat-label">メーカー業界（約7,000名）<br />社内説明スライド作成</div>
                <div class="stat-num">7<span class="unit">時間</span><span class="arrow">→</span>4<span class="unit">時間</span><sup>※2</sup></div>
                <!-- 図解1: before/after横棒バー（白地ミニカード + 青バー） -->
                <div class="stat-bars" role="img" aria-label="従来7時間が、SellPro導入後は4時間に短縮。約43%削減（※2）">
                  <div class="bar-row">
                    <span class="bar-tag">従来</span>
                    <div class="bar-track"><div class="bar before"><span class="bar-val">7時間</span></div></div>
                  </div>
                  <div class="bar-row">
                    <span class="bar-tag">SellPro</span>
                    <div class="bar-track">
                      <div class="bar after" style="--w: 57%"><span class="bar-val">4時間</span></div>
                      <span class="bar-badge">約43%削減<sup>※2</sup></span>
                    </div>
                  </div>
                </div>
              </li>
              <li class="stat stat-detail">
                <div class="stat-label">不動産・建設業界（約750名）<br />購入検討者向け説明資料</div>
                <div class="stat-num">3<span class="unit">時間</span><span class="arrow">→</span>1<span class="unit">時間</span><sup>※3</sup></div>
                <div class="stat-bars" role="img" aria-label="従来3時間が、SellPro導入後は1時間に短縮。約67%削減（※3）">
                  <div class="bar-row">
                    <span class="bar-tag">従来</span>
                    <div class="bar-track"><div class="bar before"><span class="bar-val">3時間</span></div></div>
                  </div>
                  <div class="bar-row">
                    <span class="bar-tag">SellPro</span>
                    <div class="bar-track">
                      <div class="bar after" style="--w: 33%"><span class="bar-val">1時間</span></div>
                      <span class="bar-badge">約67%削減<sup>※3</sup></span>
                    </div>
                  </div>
                </div>
              </li>
              <li class="stat">
                <div class="stat-label">文字起こしから<br />議事録完成までの目安</div>
                <div class="stat-num">3<span class="unit">〜</span>5<span class="unit">分</span><sup>※4</sup></div>
                <div class="stat-mini">録音をアップするだけ。整文・要約まで一気通貫</div>
              </li>
            </ul>
            <ul class="stats-notes">
              <li>※1〜※4 いずれも当社調べ。削減効果は資料の種類・内容により異なります。</li>
            </ul>
          </div>
        </section>
      </div>

      <!-- 4. 導入企業ロゴウォール -->
      <section class="logos" id="logos" aria-label="導入企業ロゴ">
        <div class="container">
          <div class="logo-marquee">
            <div class="logo-track">
              <ul class="logo-set">
                {
                  logos.map((l) => (
                    <li class="logo-tile">
                      <img src={`logos/${l.file}`} alt={`${l.name}のロゴ`} title={l.name} />
                    </li>
                  ))
                }
              </ul>
              <!-- シームレスループ用の複製セット（読み上げ対象外） -->
              <ul class="logo-set" aria-hidden="true">
                {
                  logos.map((l) => (
                    <li class="logo-tile">
                      <img src={`logos/${l.file}`} alt="" />
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
          <p class="logos-note">※ 受託開発でのお付き合いも含めます。</p>
        </div>
      </section>

      <!-- 6. 主な機能 -->
      <section class="features" id="features" aria-labelledby="features-h">
        <div class="container">
          <div class="sec-head">
            <span class="idx" aria-hidden="true">03</span>
            <h2 id="features-h">主な機能</h2>
            <p class="sec-lead">スライドAIと議事録AI。資料にまつわる前後の業務を、ひとつのエージェントで。</p>
          </div>
          <div class="feature-group">
            <div class="fg-label">
              {featureGroups[0].label}
              <span class="en">{featureGroups[0].en}</span>
            </div>
            <div class="feature-cards">
              {
                featureGroups[0].items.map((f) => (
                  <article class="feature-card has-mock">
                    <div class="fc-mock">
                      <FeatureMock viz={f.viz} />
                    </div>
                    <div class="fc-text">
                      <h3>{f.title}</h3>
                      <p>{f.body}</p>
                    </div>
                  </article>
                ))
              }
            </div>
            <!-- スライドAIの実UIスクショ（ブラウザ風フレーム・大きめ） -->
            <figure class="ui-shot">
              <div class="ui-window">
                <div class="ui-bar">
                  <span class="ui-dot" /><span class="ui-dot" /><span class="ui-dot" />
                  <span class="ui-url">SellPro — スライド編集</span>
                </div>
                <img
                  src="product/ui-slide-editor.png"
                  alt="SellProのスライド編集画面。スライド一覧から「スライド生成」「PPTX一括出力」、各スライドの「AIで編集」操作ができる実際の管理画面"
                  width="563"
                  height="347"
                />
              </div>
              <figcaption><span class="ui-live">実際の画面</span>指示に沿って生成し、その場で「AIで編集」。PDF・PPTXでそのまま書き出せます。</figcaption>
            </figure>
          </div>
          <div class="feature-group">
            <div class="fg-label">
              {featureGroups[1].label}
              <span class="en">{featureGroups[1].en}</span>
            </div>
            <!-- 図解3: 議事録AI 5ノード横フロー（白カード + 青アイコンスクエアに再着色） -->
            <div
              class="mflow"
              role="img"
              aria-label="議事録AIの流れ：会議を録音、自動文字起こし、誰が・何を言ったかの話者識別、議事録・ToDo抽出までが3〜5分程度（※4）。続けて次回提案資料の作成へつながります。"
            >
              <div class="mf-node">
                <span class="mf-ic">
                  <svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round">
                    <rect x="15" y="5" width="10" height="17" rx="5"></rect>
                    <path d="M10 17a10 10 0 0 0 20 0"></path>
                    <path d="M20 27v6M14 33h12"></path>
                  </svg>
                </span>
                <span class="mf-lb">会議を録音</span>
              </div>
              <div class="mf-arrow">
                <svg viewBox="0 0 20 20" fill="none"><path d="M6 3l8 7-8 7" stroke="#1c6fd2" stroke-width="3"></path></svg>
              </div>
              <div class="mf-core">
                <div class="mf-bracket"><span class="mf-badge">3〜5分<sup>※4</sup></span></div>
                <div class="mf-core-nodes">
                  <div class="mf-node">
                    <span class="mf-ic">
                      <svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round">
                        <path d="M8 16v8M14 11v18M20 14v12M26 7v26M32 16v8"></path>
                      </svg>
                    </span>
                    <span class="mf-lb">自動文字起こし</span>
                  </div>
                  <div class="mf-arrow">
                    <svg viewBox="0 0 20 20" fill="none"><path d="M6 3l8 7-8 7" stroke="#1c6fd2" stroke-width="3"></path></svg>
                  </div>
                  <div class="mf-node">
                    <span class="mf-ic">
                      <svg viewBox="0 0 40 40" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round">
